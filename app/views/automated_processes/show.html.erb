<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <div>
      <h1 class="mb-0"><%= @process[:name] %></h1>
      <p class="text-muted mb-0"><%= @process[:description] %></p>
    </div>
    <div class="d-flex gap-2">
      <%= button_to "Run Now", trigger_automated_process_path(params[:id]), method: :post, class: "btn btn-primary btn-sm" %>
      <%= link_to "Back", automated_processes_path, class: "btn btn-outline-secondary btn-sm" %>
    </div>
  </div>

  <div class="card shadow-sm mb-4">
    <div class="card-header fw-semibold">Schedule</div>
    <div class="card-body">
      <%= form_with url: update_config_automated_process_path(params[:id]), method: :patch, local: true do |f| %>
        <div class="row g-3 align-items-end">
          <div class="col-md-4">
            <%= label_tag :schedule_preset, "Run Frequency", class: "form-label" %>
            <%= select_tag :schedule_preset,
                options_for_select([
                  ['Every 1 minute',   '* * * * *'],
                  ['Every 2 minutes',  '*/2 * * * *'],
                  ['Every 5 minutes',  '*/5 * * * *'],
                  ['Every 15 minutes', '*/15 * * * *'],
                  ['Every 30 minutes', '*/30 * * * *'],
                  ['Every hour',       '0 * * * *'],
                  ['Every 2 hours',    '0 */2 * * *'],
                  ['Every 6 hours',    '0 */6 * * *'],
                  ['Every 12 hours',   '0 */12 * * *'],
                  ['Once a day (midnight)', '0 0 * * *'],
                  ['Once a day (6am)',  '0 6 * * *'],
                  ['Once a week (Sunday midnight)', '0 0 * * 0'],
                  ['Custom…',          'custom'],
                ], @config.schedule),
                class: "form-select",
                onchange: "toggleCustomSchedule(this)" %>
          </div>
          <div class="col-md-4" id="custom-schedule-field" style="<%= @config.schedule.in?(ApplicationHelper::CRON_PRESETS.values) ? 'display:none' : '' %>">
            <%= label_tag :schedule, "Custom Cron Expression", class: "form-label" %>
            <%= f.text_field :schedule, value: @config.schedule, name: "automated_process_config[schedule]",
                class: "form-control font-monospace", placeholder: "0 * * * *", id: "custom-schedule-input" %>
          </div>
          <%= f.hidden_field :schedule, value: @config.schedule, name: "automated_process_config[schedule]",
              id: "schedule-hidden" %>
          <div class="col-md-3">
            <%= label_tag :notes, "Notes", class: "form-label" %>
            <%= f.text_field :notes, value: @config.notes, name: "automated_process_config[notes]",
                class: "form-control", placeholder: "Optional notes" %>
          </div>
          <div class="col-md-1">
            <%= f.submit "Save", class: "btn btn-outline-primary w-100" %>
          </div>
        </div>
      <% end %>
      <div class="alert alert-info mt-3 mb-0 small">
        <i class="bi bi-info-circle"></i>
        Changes take effect immediately — no Render changes needed.
      </div>
    </div>
  </div>

  <script>
    function toggleCustomSchedule(select) {
      const customField = document.getElementById('custom-schedule-field');
      const hiddenInput = document.getElementById('schedule-hidden');
      const customInput = document.getElementById('custom-schedule-input');

      if (select.value === 'custom') {
        customField.style.display = '';
        customInput.name = 'automated_process_config[schedule]';
        hiddenInput.name = '';
      } else {
        customField.style.display = 'none';
        customInput.name = '';
        hiddenInput.name = 'automated_process_config[schedule]';
        hiddenInput.value = select.value;
      }
    }

    // Initialize on page load
    document.addEventListener('DOMContentLoaded', function() {
      const select = document.querySelector('[name="schedule_preset"]');
      if (select) toggleCustomSchedule(select);
    });
  </script>

  <h4>Run History</h4>
  <% if @logs.any? %>
    <div class="table-responsive">
      <table class="table table-bordered table-hover align-middle">
        <thead class="table-light">
          <tr>
            <th>Started</th>
            <th>Status</th>
            <th>File</th>
            <th>Created</th>
            <th>Updated</th>
            <th>Skipped</th>
            <th>Duration</th>
            <th>Notes</th>
          </tr>
        </thead>
        <tbody>
          <% @logs.each do |log| %>
            <tr>
              <td class="text-nowrap"><%= log.started_at.strftime('%b %-d %Y %-I:%M %p') %></td>
              <td>
                <span class="badge <%= log.status == 'success' ? 'bg-success' : log.status == 'failed' ? 'bg-danger' : log.status == 'skipped' ? 'bg-secondary' : 'bg-warning text-dark' %>">
                  <%= log.status %>
                </span>
              </td>
              <td>
                <% if log.file_content.present? %>
                  <%= link_to log.file_name, download_file_automated_process_path(params[:id], log_id: log.id), class: "small" %>
                <% else %>
                  <span class="text-muted small"><%= log.file_name %></span>
                <% end %>
              </td>
              <td><%= log.records_created %></td>
              <td><%= log.records_updated %></td>
              <td><%= log.records_skipped %></td>
              <td class="text-nowrap"><%= log.duration_s %></td>
              <td>
                <% if log.error_message.present? %>
                  <span class="text-danger small"><%= log.error_message.truncate(80) %></span>
                <% elsif log.warnings.present? %>
                  <button class="btn btn-outline-warning btn-sm py-0" type="button"
                          data-bs-toggle="collapse"
                          data-bs-target="#warnings-<%= log.id %>">
                    <%= log.warnings.lines.count %> warning(s)
                  </button>
                  <div class="collapse mt-1" id="warnings-<%= log.id %>">
                    <pre class="small text-muted mb-0" style="white-space: pre-wrap;"><%= log.warnings %></pre>
                  </div>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <%= will_paginate @logs %>
  <% else %>
    <p class="text-muted">No runs recorded yet.</p>
  <% end %>
</div>
