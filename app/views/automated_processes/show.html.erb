<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <div>
      <h1 class="mb-0"><%= @process[:name] %></h1>
      <p class="text-muted mb-0"><%= @process[:description] %></p>
    </div>
    <div class="d-flex gap-2">
      <%= button_to "Run Now", trigger_automated_process_path(params[:id]), method: :post, class: "btn btn-primary btn-sm" %>
      <%= link_to "Back", automated_processes_path, class: "btn btn-outline-secondary btn-sm" %>
    </div>
  </div>

  <div class="card shadow-sm mb-4">
    <div class="card-header fw-semibold">Schedule</div>
    <div class="card-body">
      <%= form_with url: update_config_automated_process_path(params[:id]), method: :patch, local: true do |f| %>
        <%= f.hidden_field :automated_process_config %>
        <div class="row g-3 align-items-end">
          <div class="col-md-4">
            <%= label_tag :schedule, "Cron Expression", class: "form-label" %>
            <%= f.text_field :schedule, value: @config.schedule, name: "automated_process_config[schedule]",
                class: "form-control font-monospace", placeholder: "0 * * * *" %>
            <div class="form-text">
              Current: runs <strong><%= cron_description(@config.schedule) %></strong>.
              <a href="https://crontab.guru" target="_blank">crontab.guru</a>
            </div>
          </div>
          <div class="col-md-6">
            <%= label_tag :notes, "Notes", class: "form-label" %>
            <%= f.text_field :notes, value: @config.notes, name: "automated_process_config[notes]",
                class: "form-control", placeholder: "Optional notes" %>
          </div>
          <div class="col-md-2">
            <%= f.submit "Save", class: "btn btn-outline-primary w-100" %>
          </div>
        </div>
      <% end %>
      <div class="alert alert-info mt-3 mb-0 small">
        <i class="bi bi-info-circle"></i>
        The scheduler runs every minute via Render and fires this job when it's due. Changing the schedule here takes effect immediately — no Render changes needed.
      </div>
    </div>
  </div>

  <h4>Run History</h4>
  <% if @logs.any? %>
    <div class="table-responsive">
      <table class="table table-bordered table-hover align-middle">
        <thead class="table-light">
          <tr>
            <th>Started</th>
            <th>Status</th>
            <th>File</th>
            <th>Created</th>
            <th>Updated</th>
            <th>Skipped</th>
            <th>Duration</th>
            <th>Notes</th>
          </tr>
        </thead>
        <tbody>
          <% @logs.each do |log| %>
            <tr>
              <td class="text-nowrap"><%= log.started_at.strftime('%b %-d %Y %-I:%M %p') %></td>
              <td>
                <span class="badge <%= log.status == 'success' ? 'bg-success' : log.status == 'failed' ? 'bg-danger' : 'bg-warning text-dark' %>">
                  <%= log.status %>
                </span>
              </td>
              <td>
                <% if log.file_content.present? %>
                  <%= link_to log.file_name, download_file_automated_process_path(params[:id], log_id: log.id), class: "small" %>
                <% else %>
                  <span class="text-muted small"><%= log.file_name %></span>
                <% end %>
              </td>
              <td><%= log.records_created %></td>
              <td><%= log.records_updated %></td>
              <td><%= log.records_skipped %></td>
              <td class="text-nowrap"><%= log.duration_s %></td>
              <td>
                <% if log.error_message.present? %>
                  <span class="text-danger small"><%= log.error_message.truncate(80) %></span>
                <% elsif log.warnings.present? %>
                  <button class="btn btn-outline-warning btn-sm py-0" type="button"
                          data-bs-toggle="collapse"
                          data-bs-target="#warnings-<%= log.id %>">
                    <%= log.warnings.lines.count %> warning(s)
                  </button>
                  <div class="collapse mt-1" id="warnings-<%= log.id %>">
                    <pre class="small text-muted mb-0" style="white-space: pre-wrap;"><%= log.warnings %></pre>
                  </div>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <%= will_paginate @logs %>
  <% else %>
    <p class="text-muted">No runs recorded yet.</p>
  <% end %>
</div>
