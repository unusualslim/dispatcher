<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <div>
      <h1 class="mb-1">Preview Import</h1>
      <p class="text-muted mb-0">
        <span class="badge <%= @product_type == 'finished_good' ? 'bg-warning text-dark' : 'bg-secondary' %> me-1">
          <%= @product_type == 'finished_good' ? 'Finished Products' : 'Components' %>
        </span>
        <span class="text-success fw-semibold"><%= @update_count %> products will be updated</span>
        &nbsp;&middot;&nbsp;
        <span class="text-primary fw-semibold"><%= @create_count %> new products will be created</span>
      </p>
    </div>
    <%= link_to "Cancel", new_inventory_import_path, class: "btn btn-outline-secondary" %>
  </div>

  <%= form_with url: inventory_import_path, method: :post, data: { turbo: false } do |f| %>
    <div class="card shadow-sm mb-3">
      <div class="card-header d-flex justify-content-between align-items-center">
        <span class="fw-semibold">Review & Select Rows to Import</span>
        <div class="d-flex gap-2">
          <button type="button" class="btn btn-sm btn-outline-secondary" id="selectAll">Select All</button>
          <button type="button" class="btn btn-sm btn-outline-secondary" id="selectUpdates">Updates Only</button>
          <button type="button" class="btn btn-sm btn-outline-secondary" id="deselectAll">Deselect All</button>
        </div>
      </div>
      <div class="table-responsive">
        <table class="table table-sm table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th style="width: 40px;"></th>
              <th>Part #</th>
              <th>Description</th>
              <th>Category</th>
              <th class="text-end">Qty</th>
              <th>Action</th>
              <th>Current Stock</th>
            </tr>
          </thead>
          <tbody>
            <% @rows.each do |row| %>
              <tr class="<%= row.action == :create ? 'table-primary' : '' %>">
                <td class="text-center">
                  <%= check_box_tag "selected_parts[#{row.part_number}]", "1", true,
                        class: "form-check-input import-checkbox",
                        data: { action: row.action } %>
                </td>
                <td class="font-monospace small"><%= row.part_number %></td>
                <td><%= row.description %></td>
                <td><span class="badge bg-secondary"><%= row.category %></span></td>
                <td class="text-end"><%= number_with_precision(row.quantity, precision: 2, strip_insignificant_zeros: true) %></td>
                <td>
                  <% if row.action == :update %>
                    <span class="badge bg-success">Update</span>
                  <% else %>
                    <span class="badge bg-primary">New Product</span>
                  <% end %>
                </td>
                <td class="text-muted small">
                  <% if row.product %>
                    <%= number_with_precision(row.product.current_stock, precision: 2, strip_insignificant_zeros: true) %>
                    <% if row.product.current_stock != row.quantity %>
                      <i class="bi bi-arrow-right text-muted"></i>
                      <strong class="text-dark"><%= number_with_precision(row.quantity, precision: 2, strip_insignificant_zeros: true) %></strong>
                    <% end %>
                  <% else %>
                    <span class="text-muted">—</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <div class="d-flex gap-2">
      <%= f.submit "Confirm Import", class: "btn btn-success btn-lg" %>
      <%= link_to "Cancel", new_inventory_import_path, class: "btn btn-outline-secondary btn-lg" %>
    </div>
  <% end %>
</div>

<script>
  document.getElementById('selectAll').addEventListener('click', () =>
    document.querySelectorAll('.import-checkbox').forEach(cb => cb.checked = true));
  document.getElementById('deselectAll').addEventListener('click', () =>
    document.querySelectorAll('.import-checkbox').forEach(cb => cb.checked = false));
  document.getElementById('selectUpdates').addEventListener('click', () =>
    document.querySelectorAll('.import-checkbox').forEach(cb =>
      cb.checked = cb.dataset.action === 'update'));
</script>
