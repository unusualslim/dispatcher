<div class="container mt-4" style="max-width: 600px;">
  <h1>New Purchase Order</h1>

  <%= form_with model: @purchase_order, local: true do |f| %>
    <% if @purchase_order.errors.any? %>
      <div class="alert alert-danger">
        <ul class="mb-0">
          <% @purchase_order.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="card shadow-sm mb-3">
      <div class="card-body row g-3">
        <div class="col-12">
          <%= f.label :product_id, "Product", class: 'form-label' %>
          <%= f.collection_select :product_id, @products, :id, :name,
                { include_blank: 'Select product...' }, class: 'form-select' %>
        </div>
        <div class="col-12">
          <%= f.label :vendor_id, "Vendor", class: 'form-label' %>
          <%= f.collection_select :vendor_id, @vendors, :id, :name,
                { include_blank: 'Select vendor...' }, class: 'form-select' %>
        </div>
        <div class="col-6">
          <%= f.label :quantity, class: 'form-label' %>
          <%= f.number_field :quantity, step: 0.001, class: 'form-control', placeholder: '0' %>
        </div>
        <div class="col-6">
          <%= f.label :unit_cost, "Unit Cost ($)", class: 'form-label' %>
          <%= f.number_field :unit_cost, step: 0.0001, class: 'form-control', placeholder: '0.00' %>
        </div>
        <div class="col-6">
          <%= f.label :expected_delivery_date, class: 'form-label' %>
          <%= f.date_field :expected_delivery_date, class: 'form-control' %>
        </div>
        <div class="col-6">
          <%= f.label :trigger_type, class: 'form-label' %>
          <%= f.select :trigger_type,
                PurchaseOrder::TRIGGER_TYPES.map { |t| [t.humanize, t] },
                { selected: 'manual' }, class: 'form-select' %>
        </div>
        <div class="col-12">
          <%= f.label :notes, class: 'form-label' %>
          <%= f.text_area :notes, class: 'form-control', rows: 3 %>
        </div>
      </div>
    </div>

    <div class="d-flex gap-2">
      <%= f.submit 'Create Purchase Order', class: 'btn btn-success' %>
      <%= link_to 'Cancel', purchase_orders_path, class: 'btn btn-secondary' %>
    </div>
  <% end %>
</div>
