<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="mb-0">Purchase Orders</h1>
  <div class="d-flex gap-2">
    <%= link_to 'MRP Dashboard', mrp_path, class: 'btn btn-outline-primary btn-sm' %>
    <%= link_to 'Export Approved to PDI CSV', export_pdi_purchase_orders_path, class: 'btn btn-outline-success btn-sm' %>
    <%= link_to 'Import from PDI', new_purchase_order_imports_path, class: 'btn btn-outline-primary btn-sm' %>
    <%= link_to 'New PO', new_purchase_order_path, class: 'btn btn-primary btn-sm' %>
  </div>
</div>

<%# Status filter tabs %>
<% badge_colors = { 'draft' => 'secondary', 'pending_approval' => 'warning', 'approved' => 'primary',
                    'submitted' => 'info', 'received' => 'success', 'cancelled' => 'danger' } %>
<ul class="nav nav-tabs mb-3">
  <li class="nav-item">
    <a href="<%= purchase_orders_path %>" class="nav-link <%= @status_filter.nil? ? 'active' : '' %>">
      All <span class="badge bg-secondary ms-1"><%= @status_counts.values.sum %></span>
    </a>
  </li>
  <% PurchaseOrder::STATUSES.each do |status| %>
    <% next if status == 'cancelled' && @status_counts[status] == 0 %>
    <li class="nav-item">
      <a href="<%= purchase_orders_path(status: status) %>" class="nav-link <%= @status_filter == status ? 'active' : '' %>">
        <%= status.humanize %>
        <span class="badge bg-<%= badge_colors[status] || 'secondary' %> ms-1"><%= @status_counts[status] %></span>
      </a>
    </li>
  <% end %>
</ul>

<% if @purchase_orders.empty? %>
  <div class="text-muted text-center py-5">No purchase orders<%= " with status '#{@status_filter.humanize}'" if @status_filter %>.</div>
<% else %>
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th style="width:70px">PO #</th>
          <th>Vendor</th>
          <th>Products</th>
          <th class="text-end">Total</th>
          <th>Status</th>
          <th>Date</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @purchase_orders.each do |po| %>
          <tr>
            <td><%= link_to "##{po.id}", purchase_order_path(po), class: 'fw-semibold text-decoration-none' %></td>
            <td><%= po.vendor&.name || '—' %></td>
            <td>
              <% names = po.line_items.map(&:display_name) %>
              <span class="small"><%= names.first(2).join(', ')%><%= " +#{names.size - 2} more" if names.size > 2 %></span>
              <% if po.pdi_reference.present? %>
                <br><code class="small text-muted"><%= po.pdi_reference %></code>
              <% end %>
            </td>
            <td class="text-end text-nowrap"><%= number_to_currency(po.total_cost) %></td>
            <td>
              <% color = badge_colors[po.status] || 'secondary' %>
              <span class="badge bg-<%= color %>"><%= po.status.humanize %></span>
              <% if po.posted? %>
                <span class="badge bg-success mt-1">Posted</span>
              <% elsif po.status == 'received' %>
                <span class="badge bg-warning text-dark mt-1">Unposted</span>
              <% end %>
            </td>
            <td class="text-nowrap small text-muted">
              <% if po.received_at %>
                Rcvd <%= po.received_at.strftime('%b %-d') %>
              <% elsif po.expected_delivery_date %>
                Exp <%= po.expected_delivery_date.strftime('%b %-d') %>
              <% else %>
                <%= po.created_at.strftime('%b %-d') %>
              <% end %>
            </td>
            <td class="text-end">
              <div class="d-flex gap-1 justify-content-end">
                <% if po.status == 'draft' %>
                  <%= button_to 'Approve', approve_purchase_order_path(po), method: :patch, class: 'btn btn-sm btn-success' %>
                <% elsif po.status == 'approved' %>
                  <%= button_to 'Submit', submit_purchase_order_path(po), method: :patch, class: 'btn btn-sm btn-info' %>
                <% elsif po.status == 'submitted' %>
                  <%= button_to 'Receive', receive_purchase_order_path(po), method: :patch, class: 'btn btn-sm btn-primary' %>
                <% elsif po.status == 'received' && !po.posted? %>
                  <%= button_to 'Post', post_to_inventory_purchase_order_path(po), method: :patch, class: 'btn btn-sm btn-success',
                        data: { confirm: 'Post this PO to inventory?' } %>
                <% end %>
                <%= link_to 'View', purchase_order_path(po), class: 'btn btn-sm btn-outline-secondary' %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
