<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="mb-0">Purchase Orders</h1>
  <div class="d-flex gap-2">
    <%= link_to 'MRP Dashboard', mrp_path, class: 'btn btn-outline-primary btn-sm' %>
    <%= link_to 'Export Approved to PDI CSV', export_pdi_purchase_orders_path, class: 'btn btn-outline-success btn-sm' %>
    <%= link_to 'New PO', new_purchase_order_path, class: 'btn btn-primary btn-sm' %>
  </div>
</div>

<% statuses = PurchaseOrder::STATUSES %>
<% grouped = @purchase_orders.group_by(&:status) %>

<% statuses.each do |status| %>
  <% orders = grouped[status] %>
  <% next if orders.blank? && status == 'cancelled' %>

  <h5 class="text-capitalize mt-4 mb-2">
    <%= status.humanize %>
    <span class="badge bg-secondary ms-1"><%= orders&.count || 0 %></span>
  </h5>

  <% if orders.present? %>
    <table class="table table-sm table-hover mb-0">
      <thead class="table-light">
        <tr>
          <th>PO #</th>
          <th>Product</th>
          <th>Vendor</th>
          <th>Qty</th>
          <th>Total Cost</th>
          <th>Trigger</th>
          <th>Expected</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% orders.each do |po| %>
          <tr>
            <td><%= link_to "##{po.id}", purchase_order_path(po), class: 'text-decoration-none fw-semibold' %></td>
            <td><%= po.product&.name %></td>
            <td><%= po.vendor&.name %></td>
            <td><%= number_with_precision(po.quantity, precision: 1) %> <%= po.product&.unit_of_measurement %></td>
            <td><%= po.total_cost ? number_to_currency(po.total_cost) : '—' %></td>
            <td><span class="badge bg-light text-dark border"><%= po.trigger_type&.humanize || '—' %></span></td>
            <td><%= po.expected_delivery_date&.strftime('%b %d') || '—' %></td>
            <td><%= link_to 'View', purchase_order_path(po), class: 'btn btn-sm btn-outline-secondary' %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
<% end %>
