<% total_new    = @vendor_groups.sum { |g| g.pos.count { |p| !p.already_imported } }
   total_skip   = @vendor_groups.sum { |g| g.pos.count(&:already_imported) }
   missing_vend = @vendor_groups.select { |g| g.vendor.nil? } %>

<div class="d-flex justify-content-between align-items-start mb-3">
  <div>
    <h1 class="mb-1">Preview PO Import</h1>
    <p class="text-muted mb-0">
      <span class="text-success fw-semibold"><%= total_new %> POs ready to import</span>
      &nbsp;&middot;&nbsp;Importing as <strong><%= @import_status.humanize %></strong>
      <% if total_skip > 0 %>
        &nbsp;&middot;&nbsp;<span class="text-muted"><%= total_skip %> already imported (will skip)</span>
      <% end %>
      <% if missing_vend.any? %>
        &nbsp;&middot;&nbsp;<span class="text-danger fw-semibold"><%= missing_vend.count %> vendor(s) not found</span>
      <% end %>
    </p>
  </div>
  <%= link_to "Cancel", new_purchase_order_imports_path, class: "btn btn-outline-secondary" %>
</div>

<%= form_with url: purchase_order_imports_path, method: :post, data: { turbo: false } do |f| %>
  <%= hidden_field_tag :import_status, @import_status %>

  <%# Missing vendors panel %>
  <% if missing_vend.any? %>
    <div class="card border-warning shadow-sm mb-4">
      <div class="card-header bg-warning bg-opacity-10 fw-semibold text-warning-emphasis">
        Vendors Not Found — Review Before Importing
      </div>
      <div class="card-body pb-2">
        <p class="small text-muted mb-3">These vendor IDs appear in the file but aren't in the system. For each one, choose to skip, create a new vendor, or match to an existing one.</p>
        <% missing_vend.each do |group| %>
          <div class="row align-items-center g-2 mb-3 p-2 border rounded mx-0">
            <div class="col-auto">
              <code class="text-muted"><%= group.vendor_id %></code>
            </div>
            <div class="col">
              <div class="fw-semibold"><%= group.vendor_name %></div>
              <div class="small text-muted"><%= group.pos.count { |p| !p.already_imported } %> PO(s)</div>
            </div>
            <div class="col-md-5">
              <%= select_tag "vendor_actions[#{group.vendor_id}]",
                    options_for_select(
                      [['— Skip these POs —', 'skip'],
                       ["Create new: \"#{group.vendor_name}\"", 'create']] +
                      [['--- Match to existing vendor ---', '']] +
                      @existing_vendors,
                      'skip'
                    ),
                    class: 'form-select form-select-sm',
                    disabled: group.pos.all?(&:already_imported) %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# POs by vendor %>
  <% @vendor_groups.each do |group| %>
    <div class="card shadow-sm mb-3">
      <div class="card-header d-flex justify-content-between align-items-center">
        <div>
          <span class="fw-semibold"><%= group.vendor_name %></span>
          <code class="small text-muted ms-2"><%= group.vendor_id %></code>
          <% if group.vendor %>
            <span class="badge bg-success ms-2">Matched: <%= group.vendor.name %></span>
          <% else %>
            <span class="badge bg-warning text-dark ms-2">Vendor not found</span>
          <% end %>
        </div>
        <span class="text-muted small"><%= group.pos.count %> PO(s)</span>
      </div>
      <div class="table-responsive">
        <table class="table table-sm table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th style="width:36px"></th>
              <th>PDI Reference</th>
              <th class="text-end">Lines</th>
              <th class="text-end">Total Cost</th>
              <th>Date</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% group.pos.each_with_index do |po, i| %>
              <% collapse_id = "lines-#{group.vendor_id.parameterize}-#{i}" %>
              <tr class="<%= po.already_imported ? 'text-muted' : '' %>">
                <td class="text-center">
                  <% if po.already_imported %>
                    <input type="checkbox" class="form-check-input" disabled>
                  <% else %>
                    <%= check_box_tag "selected_refs[#{po.pdi_reference}]", "1", true,
                          class: "form-check-input po-checkbox",
                          data: { vendor: group.vendor_id } %>
                  <% end %>
                </td>
                <td class="font-monospace">
                  <a class="text-decoration-none" data-bs-toggle="collapse" href="#<%= collapse_id %>" style="cursor:pointer">
                    <%= po.pdi_reference %>
                    <i class="bi bi-chevron-down small ms-1"></i>
                  </a>
                </td>
                <td class="text-end"><%= po.line_count %></td>
                <td class="text-end"><%= number_to_currency(po.total_cost) %></td>
                <td><%= po.business_date&.strftime('%b %-d, %Y') || '—' %></td>
                <td>
                  <% if po.already_imported %>
                    <span class="badge bg-secondary">Already imported</span>
                  <% else %>
                    <span class="badge bg-success">Ready</span>
                  <% end %>
                </td>
              </tr>
              <tr class="collapse" id="<%= collapse_id %>">
                <td colspan="6" class="p-0 border-0">
                  <table class="table table-sm mb-0 bg-light">
                    <thead>
                      <tr class="text-muted small">
                        <th class="ps-4">Product ID</th>
                        <th>Description</th>
                        <th>Unit</th>
                        <th class="text-end">Qty</th>
                        <th class="text-end">Unit Cost</th>
                        <th class="text-end">Total</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% po.lines.each do |line| %>
                        <tr class="small">
                          <td class="ps-4 font-monospace text-muted"><%= line.product_id %></td>
                          <td><%= line.product_name %></td>
                          <td><%= line.package_code %></td>
                          <td class="text-end"><%= number_with_precision(line.quantity, precision: 2, strip_insignificant_zeros: true) %></td>
                          <td class="text-end"><%= number_to_currency(line.unit_cost) %></td>
                          <td class="text-end"><%= number_to_currency(line.quantity * line.unit_cost) %></td>
                        </tr>
                      <% end %>
                    </tbody>
                  </table>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>

  <div class="d-flex gap-2 mt-3 mb-5">
    <%= f.submit "Confirm Import", class: "btn btn-success btn-lg" %>
    <%= link_to "Cancel", new_purchase_order_imports_path, class: "btn btn-outline-secondary btn-lg" %>
  </div>
<% end %>
