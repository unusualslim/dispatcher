<%= form_with(model: customer_order, data: { turbo: false }, id: "customer-order-form") do |form| %>

  <%# ── Errors ─────────────────────────────────────────────────────────────── %>
  <% if customer_order.errors.any? %>
    <div class="alert alert-danger mb-4">
      <strong><%= pluralize(customer_order.errors.count, "error") %> prevented this order from being saved:</strong>
      <ul class="mb-0 mt-1">
        <% customer_order.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row g-4">

    <%# ── Left column: Customer & Destination ───────────────────────────────── %>
    <div class="col-lg-6">
      <div class="card shadow-sm h-100">
        <div class="card-header fw-semibold">Delivery Info</div>
        <div class="card-body d-flex flex-column gap-3">

          <%# Customer %>
          <div>
            <%= form.label :customer_id, "Customer", class: "form-label fw-semibold mb-1" %>
            <%= form.select :customer_id,
                  Customer.order(:name).map { |c| [c.name, c.id] },
                  { include_blank: "— Select a customer —" },
                  class: "form-select co-customer-select" %>
          </div>

          <%# Destination %>
          <div>
            <div class="d-flex justify-content-between align-items-center mb-1">
              <%= form.label :location_id, "Destination", class: "form-label fw-semibold mb-0" %>
              <button type="button" class="btn btn-link btn-sm p-0 text-decoration-none" id="new-location-btn">
                + New destination
              </button>
            </div>
            <input type="hidden" id="co_location_id" name="customer_order[location_id]"
                   value="<%= customer_order.location_id %>">
            <select id="co_location_search" class="form-select" style="width: 100%;">
              <% if customer_order.location_id.present? && customer_order.location.present? %>
                <option value="<%= customer_order.location_id %>" selected>
                  <%= customer_order.location.city_with_company %>
                </option>
              <% end %>
            </select>
            <div class="form-text">Search by company name or city</div>
          </div>

        </div>
      </div>
    </div>

    <%# ── Right column: Order Details ───────────────────────────────────────── %>
    <div class="col-lg-6">
      <div class="card shadow-sm h-100">
        <div class="card-header fw-semibold">Order Details</div>
        <div class="card-body d-flex flex-column gap-3">

          <%# Delivery Date %>
          <div>
            <%= form.label :required_delivery_date, "Required Delivery Date", class: "form-label fw-semibold mb-1" %>
            <%= form.date_field :required_delivery_date, class: "form-control" %>
          </div>

          <%# Approximate Amount %>
          <div>
            <%= form.label :approximate_product_amount, "Approximate Amount", class: "form-label fw-semibold mb-1" %>
            <div class="input-group">
              <%= form.number_field :approximate_product_amount,
                    class: "form-control",
                    placeholder: "e.g. 5000",
                    step: "any", min: 0 %>
              <span class="input-group-text">gal</span>
            </div>
          </div>

          <%# Order Status (only on edit) %>
          <% if customer_order.persisted? %>
            <div>
              <%= form.label :order_status, "Status", class: "form-label fw-semibold mb-1" %>
              <%= form.select :order_status,
                    CustomerOrder.order_statuses.keys.map { |s| [s.humanize, s] },
                    {},
                    class: "form-select" %>
            </div>
          <% end %>

          <%# Freight Only %>
          <div class="form-check form-switch mt-1">
            <%= form.check_box :freight_only, class: "form-check-input", role: "switch", id: "freight_only_toggle" %>
            <%= form.label :freight_only, "Freight Only", class: "form-check-label fw-semibold", for: "freight_only_toggle" %>
            <div class="form-text">Check if this is a freight-only order (no product)</div>
          </div>

        </div>
      </div>
    </div>

    <%# ── Products ──────────────────────────────────────────────────────────── %>
    <div class="col-12">
      <div class="card shadow-sm">
        <div class="card-header fw-semibold d-flex justify-content-between align-items-center">
          <span>Products</span>
          <button type="button" class="btn btn-sm btn-outline-primary" id="add-product-row">
            + Add Product
          </button>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-sm align-middle mb-0" id="products-table">
              <thead class="table-light">
                <tr>
                  <th>Product</th>
                  <th style="width: 150px;">Quantity</th>
                  <th style="width: 150px;">Price / unit</th>
                  <th style="width: 48px;"></th>
                </tr>
              </thead>
              <tbody id="product-rows">
                <% customer_order.customer_order_products.each.with_index do |cop, i| %>
                  <%= render "product_row", form: form, cop: cop, index: i %>
                <% end %>
              </tbody>
            </table>
          </div>
          <div class="p-3 text-muted small border-top" id="no-products-msg"
               style="<%= customer_order.customer_order_products.any? ? 'display:none' : '' %>">
            No products added yet. Click <strong>+ Add Product</strong> to add one.
          </div>
        </div>
      </div>
    </div>

    <%# ── Notes ─────────────────────────────────────────────────────────────── %>
    <div class="col-12">
      <div class="card shadow-sm">
        <div class="card-header fw-semibold">Notes</div>
        <div class="card-body">
          <%= form.text_area :notes,
                class: "form-control",
                rows: 3,
                placeholder: "Any special instructions, delivery notes, or other info..." %>
        </div>
      </div>
    </div>

    <%# ── Actions ────────────────────────────────────────────────────────────── %>
    <div class="col-12 d-flex justify-content-end gap-2 pb-4">
      <%= link_to "Cancel", customer_orders_path, class: "btn btn-outline-secondary" %>
      <%= form.submit customer_order.persisted? ? "Save Changes" : "Create Order",
            class: "btn btn-primary px-4" %>
    </div>

  </div>

<% end %>

<%# ── New Destination Modal ──────────────────────────────────────────────────── %>
<div class="modal fade" id="locationModal" tabindex="-1" aria-labelledby="locationModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="locationModalLabel">Create New Destination</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <label for="new-company-name" class="form-label">Company Name <span class="text-danger">*</span></label>
          <input type="text" class="form-control" id="new-company-name" placeholder="e.g. Acme Corp">
        </div>
        <div class="mb-3">
          <label for="new-city" class="form-label">City <span class="text-danger">*</span></label>
          <input type="text" class="form-control" id="new-city" placeholder="e.g. Albany">
        </div>
        <div class="mb-3">
          <label for="new-state" class="form-label">State</label>
          <input type="text" class="form-control" id="new-state" placeholder="e.g. GA" maxlength="2">
        </div>
        <div id="location-modal-error" class="alert alert-danger d-none"></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" id="submit-location">Create Destination</button>
      </div>
    </div>
  </div>
</div>

<%# ── Product row template (hidden, cloned by JS) ───────────────────────────── %>
<template id="product-row-template">
  <tr class="product-row">
    <td>
      <select name="customer_order[customer_order_products_attributes][__INDEX__][product_id]"
              class="form-select form-select-sm co-product-select">
        <option value="">— Select product —</option>
        <% Product.order(:name).each do |p| %>
          <option value="<%= p.id %>"><%= p.name %></option>
        <% end %>
      </select>
    </td>
    <td>
      <input type="number" step="any" min="0"
             name="customer_order[customer_order_products_attributes][__INDEX__][quantity]"
             class="form-control form-control-sm" placeholder="0">
    </td>
    <td>
      <div class="input-group input-group-sm">
        <span class="input-group-text">$</span>
        <input type="number" step="0.01" min="0"
               name="customer_order[customer_order_products_attributes][__INDEX__][price]"
               class="form-control" placeholder="0.00">
      </div>
    </td>
    <td>
      <button type="button" class="btn btn-sm btn-outline-danger remove-product-row" title="Remove">
        &times;
      </button>
    </td>
  </tr>
</template>

<script>
(function() {
  function initOrderForm() {
    // ── Select2: Customer ──────────────────────────────────────────────────
    if (window.$) {
      $('.co-customer-select').select2({
        placeholder: '— Select a customer —',
        allowClear: true,
        width: '100%'
      });

      // ── Select2: Location AJAX ─────────────────────────────────────────
      $('#co_location_search').select2({
        placeholder: 'Search by company or city…',
        allowClear: true,
        width: '100%',
        minimumInputLength: 1,
        ajax: {
          url: '/locations/search',
          dataType: 'json',
          delay: 250,
          data: function(params) { return { query: params.term }; },
          processResults: function(data) {
            return {
              results: data.map(function(loc) {
                return { id: loc.id, text: loc.city_with_company };
              })
            };
          },
          cache: true
        }
      });

      $('#co_location_search').on('select2:select', function(e) {
        document.getElementById('co_location_id').value = e.params.data.id;
      });

      $('#co_location_search').on('select2:clear', function() {
        document.getElementById('co_location_id').value = '';
      });

      // ── Select2: Product selects ───────────────────────────────────────
      initProductSelects();
    }

    // ── New Destination modal ──────────────────────────────────────────────
    var newLocBtn = document.getElementById('new-location-btn');
    if (newLocBtn) {
      newLocBtn.addEventListener('click', function() {
        var modal = new bootstrap.Modal(document.getElementById('locationModal'));
        modal.show();
      });
    }

    var submitLocBtn = document.getElementById('submit-location');
    if (submitLocBtn) {
      submitLocBtn.addEventListener('click', function() {
        var name  = document.getElementById('new-company-name').value.trim();
        var city  = document.getElementById('new-city').value.trim();
        var state = document.getElementById('new-state').value.trim();
        var errEl = document.getElementById('location-modal-error');

        if (!name || !city) {
          errEl.textContent = 'Company name and city are required.';
          errEl.classList.remove('d-none');
          return;
        }
        errEl.classList.add('d-none');

        fetch('/locations', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json',
            'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
          },
          body: JSON.stringify({
            location: { company_name: name, city: city, state: state, location_category_id: 2 }
          })
        })
        .then(function(r) {
          if (!r.ok) {
            return r.json().then(function(errs) {
              var msgs = Object.entries(errs).map(function(e) { return e[0] + ' ' + e[1]; }).join(', ');
              throw new Error(msgs || 'Validation failed');
            });
          }
          return r.json();
        })
        .then(function(loc) {
          // Add to Select2 and select it
          var opt = new Option(loc.city_with_company, loc.id, true, true);
          $('#co_location_search').append(opt).trigger('change');
          document.getElementById('co_location_id').value = loc.id;

          // Reset & close modal
          document.getElementById('new-company-name').value = '';
          document.getElementById('new-city').value = '';
          document.getElementById('new-state').value = '';
          bootstrap.Modal.getInstance(document.getElementById('locationModal')).hide();
        })
        .catch(function(err) {
          errEl.textContent = err.message || 'Error creating destination. Please try again.';
          errEl.classList.remove('d-none');
        });
      });
    }

    // ── Product rows: Add ──────────────────────────────────────────────────
    var addBtn = document.getElementById('add-product-row');
    if (addBtn) {
      addBtn.addEventListener('click', function() {
        addProductRow();
      });
    }

    // ── Product rows: Remove (existing rows) ──────────────────────────────
    document.getElementById('product-rows').addEventListener('click', function(e) {
      if (e.target.classList.contains('remove-product-row')) {
        var row = e.target.closest('tr');
        // If persisted row, mark for destroy instead of removing
        var destroyInput = row.querySelector('input[name*="_destroy"]');
        if (destroyInput) {
          destroyInput.value = '1';
          row.style.display = 'none';
        } else {
          row.remove();
        }
        updateNoProductsMsg();
      }
    });
  }

  var rowIndex = <%= customer_order.customer_order_products.size %>;

  function addProductRow() {
    var template = document.getElementById('product-row-template');
    var clone = template.content.cloneNode(true);
    var html = clone.querySelector('tr').outerHTML;
    html = html.replace(/__INDEX__/g, rowIndex);
    rowIndex++;

    var tbody = document.getElementById('product-rows');
    tbody.insertAdjacentHTML('beforeend', html);

    // Init Select2 on the new select
    if (window.$) {
      var newSelect = tbody.querySelectorAll('.co-product-select');
      $(newSelect[newSelect.length - 1]).select2({
        placeholder: '— Select product —',
        width: '100%'
      });
    }

    updateNoProductsMsg();
  }

  function initProductSelects() {
    $('.co-product-select').each(function() {
      if (!$(this).hasClass('select2-hidden-accessible')) {
        $(this).select2({ placeholder: '— Select product —', width: '100%' });
      }
    });
  }

  function updateNoProductsMsg() {
    var rows = document.querySelectorAll('#product-rows tr:not([style*="display: none"])');
    var msg  = document.getElementById('no-products-msg');
    if (msg) msg.style.display = rows.length === 0 ? '' : 'none';
  }

  // Fire on Turbo navigation and initial page load
  document.addEventListener('turbo:load', initOrderForm);
  if (document.readyState !== 'loading') {
    initOrderForm();
  }
})();
</script>
