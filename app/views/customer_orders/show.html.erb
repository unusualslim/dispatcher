<% location = Location.find_by(id: @customer_order.location_id) %>

<%# ── Page header ──────────────────────────────────────────────────────────── %>
<div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
  <div>
    <h1 class="mb-0">Order #<%= @customer_order.id %></h1>
    <div class="text-muted small">
      <% status_color = { "New" => "primary", "Complete" => "success", "On Hold" => "warning", "Deleted" => "danger" }.fetch(@customer_order.order_status.to_s, "secondary") %>
      <span class="badge bg-<%= status_color %>"><%= @customer_order.order_status.to_s.presence || "Unknown" %></span>
      <% if @customer_order.freight_only? %>
        <span class="badge bg-dark ms-1">Freight Only</span>
      <% end %>
      <% if @customer_order.required_delivery_date %>
        &mdash; Due <%= @customer_order.required_delivery_date.strftime("%B %-d, %Y") %>
      <% end %>
    </div>
  </div>
  <div class="d-flex flex-wrap gap-2">
    <% if @customer_order.order_status == "New" %>
      <%= link_to "Create Dispatch", new_dispatch_path(customer_order_id: @customer_order.id),
            class: "btn btn-primary btn-sm" %>
    <% end %>
    <%= link_to "Edit", edit_customer_order_path(@customer_order),
          class: "btn btn-outline-secondary btn-sm", data: { turbo: false } %>
    <%= link_to "All Orders", customer_orders_path,
          class: "btn btn-outline-secondary btn-sm", data: { turbo: false } %>
  </div>
</div>

<% if notice.present? %>
  <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
    <%= notice %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% end %>

<% if @customer_order.freight_only? %>
  <div class="alert alert-warning mb-4">
    <strong>Freight Only</strong> — This order is marked as freight only, no product delivery.
  </div>
<% end %>

<div class="row g-4">

  <%# ── Order details ──────────────────────────────────────────────────────── %>
  <div class="col-lg-6">
    <div class="card shadow-sm h-100">
      <div class="card-header fw-semibold">Order Details</div>
      <div class="card-body d-flex flex-column gap-3">

        <div>
          <div class="text-muted small text-uppercase fw-semibold mb-1">Customer</div>
          <div class="fw-semibold"><%= @customer_order.customer&.name || "Not assigned" %></div>
        </div>

        <div>
          <div class="text-muted small text-uppercase fw-semibold mb-1">Destination</div>
          <% if location %>
            <%= link_to location_path(location), class: "fw-semibold text-decoration-none d-block" do %>
              <%= location.company_name %>
            <% end %>
            <div class="text-muted small"><%= [location.address, location.city, location.state, location.zip].compact_blank.join(", ") %></div>
            <% if location.notes.present? %>
              <div class="text-muted small mt-1"><em><%= location.notes %></em></div>
            <% end %>
          <% else %>
            <span class="text-muted">No destination set</span>
          <% end %>
        </div>

        <div>
          <div class="text-muted small text-uppercase fw-semibold mb-1">Required Delivery Date</div>
          <div class="fw-semibold"><%= @customer_order.required_delivery_date&.strftime("%B %-d, %Y") || "Not set" %></div>
        </div>

        <div>
          <div class="text-muted small text-uppercase fw-semibold mb-1">Approximate Amount</div>
          <div class="fw-semibold">
            <%= @customer_order.approximate_product_amount.present? ? "#{number_with_delimiter(@customer_order.approximate_product_amount)} gal" : "Not set" %>
          </div>
        </div>

      </div>
    </div>
  </div>

  <%# ── Notes & Dispatches ─────────────────────────────────────────────────── %>
  <div class="col-lg-6">
    <div class="card shadow-sm h-100">
      <div class="card-header fw-semibold">Notes</div>
      <div class="card-body">
        <% if @customer_order.notes.present? %>
          <%= simple_format(@customer_order.notes) %>
        <% else %>
          <span class="text-muted">No notes.</span>
        <% end %>
      </div>
    </div>
  </div>

  <%# ── Products ───────────────────────────────────────────────────────────── %>
  <div class="col-12">
    <div class="card shadow-sm">
      <div class="card-header fw-semibold d-flex justify-content-between align-items-center">
        <span>Products</span>
        <button type="button" class="btn btn-sm btn-outline-primary"
                data-bs-toggle="modal" data-bs-target="#addProductModal">
          + Add Product
        </button>
      </div>
      <% if @customer_order.customer_order_products.any? %>
        <div class="table-responsive">
          <table class="table table-sm align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>Product</th>
                <th style="width:130px;">Qty (gal)</th>
                <th style="width:130px;">Price/unit</th>
                <th style="width:100px;">Total</th>
                <th style="width:120px;"></th>
              </tr>
            </thead>
            <tbody>
              <% total_sum = 0 %>
              <% @customer_order.customer_order_products.each do |cop| %>
                <% total_sum += (cop.quantity || 0) * (cop.price || 0.0) %>
                <tr>
                  <%= form_with model: [@customer_order, cop], method: :patch, local: true,
                        data: { turbo: false }, class: "d-contents" do |f| %>
                    <td>
                      <%= f.collection_select :product_id, Product.order(:name), :id, :name,
                            { selected: cop.product_id, include_blank: "— Select —" },
                            class: "form-select form-select-sm" %>
                    </td>
                    <td>
                      <%= f.number_field :quantity, value: cop.quantity,
                            class: "form-control form-control-sm", min: 0, step: "any" %>
                    </td>
                    <td>
                      <div class="input-group input-group-sm">
                        <span class="input-group-text">$</span>
                        <%= f.number_field :price, value: cop.price,
                              class: "form-control", step: 0.01, min: 0 %>
                      </div>
                    </td>
                    <td class="text-nowrap"><%= number_to_currency((cop.quantity || 0) * (cop.price || 0.0)) %></td>
                    <td>
                      <div class="d-flex gap-1">
                        <%= f.submit "Save", class: "btn btn-success btn-sm" %>
                        <%= button_to "Remove",
                              customer_order_customer_order_product_path(@customer_order, cop),
                              method: :delete,
                              data: { confirm: "Remove this product?" },
                              class: "btn btn-outline-danger btn-sm" %>
                      </div>
                    </td>
                  <% end %>
                </tr>
              <% end %>
            </tbody>
            <tfoot>
              <tr class="fw-semibold table-light">
                <td colspan="3" class="text-end">Order Total</td>
                <td><%= number_to_currency(total_sum) %></td>
                <td></td>
              </tr>
            </tfoot>
          </table>
        </div>
      <% else %>
        <div class="card-body text-muted">
          No products on this order. Click <strong>+ Add Product</strong> to add one.
        </div>
      <% end %>
    </div>
  </div>

  <%# ── Associated Dispatches ──────────────────────────────────────────────── %>
  <div class="col-12">
    <div class="card shadow-sm">
      <div class="card-header fw-semibold">Dispatches</div>
      <% if @customer_order.dispatches.any? %>
        <div class="card-body p-0">
          <% @customer_order.dispatches.each do |dispatch| %>
            <%= link_to dispatch_path(dispatch), class: "text-decoration-none text-reset" do %>
              <div class="d-flex flex-wrap justify-content-between align-items-center px-3 py-2 border-bottom dispatch-row">
                <div>
                  <span class="fw-semibold">Dispatch #<%= dispatch.id %></span>
                  <% driver = User.find_by(id: dispatch.driver_id) %>
                  <span class="text-muted small ms-2"><%= driver ? driver.full_name : "No driver" %></span>
                </div>
                <div class="text-muted small">
                  <%= dispatch.dispatch_date&.strftime("%b %-d, %Y") %>
                  &mdash;
                  <% d_color = { "New" => "secondary", "Sent to Driver" => "primary", "Complete" => "success", "Billed" => "warning" }.fetch(dispatch.status.to_s, "secondary") %>
                  <span class="badge bg-<%= d_color %>"><%= dispatch.status %></span>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <div class="card-body text-muted">No dispatches associated with this order.</div>
      <% end %>
    </div>
  </div>

  <%# ── Danger zone ─────────────────────────────────────────────────────────── %>
  <div class="col-12 pb-4 text-end">
    <%= button_to "Delete Order", @customer_order, method: :delete,
          class: "btn btn-outline-danger btn-sm",
          data: { confirm: "Are you sure you want to delete this order?", turbo: false } %>
  </div>

</div>

<%# ── Add Product Modal ───────────────────────────────────────────────────── %>
<div class="modal fade" id="addProductModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Add Product to Order</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <%= form_with model: [@customer_order, CustomerOrderProduct.new], local: true,
            data: { turbo: false } do |f| %>
        <div class="modal-body d-flex flex-column gap-3">
          <div>
            <%= f.label :product_id, "Product", class: "form-label fw-semibold" %>
            <%= f.collection_select :product_id, Product.order(:name), :id, :name,
                  { include_blank: "— Select a product —" }, class: "form-select" %>
          </div>
          <div>
            <%= f.label :quantity, "Quantity (gal)", class: "form-label fw-semibold" %>
            <%= f.number_field :quantity, class: "form-control", min: 0, step: "any", placeholder: "0" %>
          </div>
          <div>
            <%= f.label :price, "Price / unit", class: "form-label fw-semibold" %>
            <div class="input-group">
              <span class="input-group-text">$</span>
              <%= f.number_field :price, class: "form-control", step: 0.01, min: 0, placeholder: "0.00" %>
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <%= f.submit "Add Product", class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<style>
  .dispatch-row:hover { background-color: var(--bs-light); }
  .d-contents { display: contents; }
</style>
