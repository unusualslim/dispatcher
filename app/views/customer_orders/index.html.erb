<head>
  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
  <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
</head>

<div class="content">
  <p style="color: green"><%= notice %></p>
  <h1>Customer Orders</h1>
  <% unless driver? %>
    <%= link_to "New Order", new_customer_order_path, class: "btn btn-primary mb-3" %>
  <% end %>

  <!-- Search and Sorting Form -->
  <div class="mb-4">
    <%= form_with url: customer_orders_path, method: :get, local: true,
          data: { turbo_frame: "orders-results" }, id: "orders-filter-form" do |f| %>
      <div class="row mb-3">
        <!-- Text search -->
        <div class="col-md-6">
          <%= f.label :q, 'Search' %>
          <%= f.text_field :q, value: params[:q], placeholder: 'Order no, invoice, customer, or location…',
                class: 'form-control', id: 'order-search', autocomplete: 'off' %>
        </div>

        <!-- Order Status -->
        <div class="col-md-3">
          <%= f.label :order_status, 'Status' %>
          <%= f.select :order_status,
                options_for_select([
                  ['New', 'New'],
                  ['Complete', 'Complete'],
                  ['On Hold', 'On Hold'],
                  ['Deleted', 'Deleted'],
                ], params[:order_status]),
                { include_blank: 'All Statuses' },
                class: 'form-control' %>
        </div>
      </div>

      <div class="row mb-3">
        <!-- Customer Select (NEW) -->
        <div class="col-md-3">
          <%= f.label :customer_id, 'Customer' %>
          <%= f.select :customer_id,
                options_from_collection_for_select(
                  @customers, :id, :name, params[:customer_id]
                ),
                { include_blank: 'All Customers' },
                class: 'form-control customer-select' %>
        </div>

        <!-- Product Select -->
        <div class="col-md-3">
          <%= f.label :product, 'Product' %>
          <%= f.select :product,
                options_from_collection_for_select(@products, :name, :name, params[:product]),
                { include_blank: 'Select a Product' },
                class: 'form-control' %>
        </div>

        <!-- Location Select -->
        <div class="col-md-3">
          <%= f.label :location, 'Location' %>
          <%= f.select :location,
                options_from_collection_for_select(
                  @locations,
                  :id,
                  ->(loc) { "#{loc.address}, #{loc.city}, #{loc.state} #{loc.zip}" },
                  params[:location]
                ),
                { include_blank: 'Select Location' },
                class: 'form-control location-select' %>
        </div>

        <!-- Freight Only Checkbox -->
        <div class="col-md-3" style="padding-top: 25px;">
          <%= f.label :freight_only, 'Freight Only' %>
          <%= f.check_box :freight_only,
                { checked: params[:freight_only].present? },
                true, false %>
        </div>
      </div>

      <div class="row mb-3">
        <!-- Sort By Dropdown -->
        <div class="col-md-3">
          <%= f.label :sort_by, 'Sort By' %>
          <%= f.select :sort_by,
                options_for_select([
                  ['Newest', 'newest'],
                  ['Oldest', 'oldest'],
                  ['Required Delivery Date', 'required_delivery_date']
                ], params[:sort_by]),
                { include_blank: 'Select Sorting' },
                class: 'form-control' %>
        </div>

        <!-- Hidden View Field -->
        <%= f.hidden_field :view, value: params[:view] || 'card' %>

        <!-- Submit and Reset Buttons -->
        <div class="col-md-2">
          <%= f.submit 'Apply Filters', class: 'btn btn-primary w-100' %>
        </div>
        <div class="col-md-2">
          <%= link_to 'Reset', customer_orders_path, class: 'btn btn-secondary w-100' %>
        </div>
      </div>
    <% end %>
  </div>

  <%= turbo_frame_tag "orders-results", target: "_top" do %>
    <!-- Toggle View Buttons -->
    <div class="mb-4">
      <%= link_to "Card View",
                  customer_orders_path(view: "card", sort_by: params[:sort_by], customer_id: params[:customer_id]),
                  class: "btn btn-secondary me-2" %>
      <%= link_to "Table View",
                  customer_orders_path(view: "table", sort_by: params[:sort_by], customer_id: params[:customer_id]),
                  class: "btn btn-secondary" %>
    </div>

    <!-- Display Content -->
    <% if params[:view] == "table" %>
      <%= render partial: "customer_orders_table", locals: { customer_orders: @customer_orders } %>
    <% else %>
      <%= render partial: "customer_orders_cards", locals: { customer_orders: @customer_orders } %>
    <% end %>

    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mt-4 mb-2">
      <div class="text-muted small">
        Showing <%= @customer_orders.offset + 1 %>–<%= [@customer_orders.offset + @customer_orders.length, @customer_orders.total_entries].min %>
        of <%= @customer_orders.total_entries %> orders
      </div>
      <nav aria-label="Orders pagination">
        <%= will_paginate @customer_orders, renderer: BootstrapPaginationRenderer %>
      </nav>
    </div>
  <% end %>
</div>

<script>
  $(document).ready(function() {
    $('.customer-select').select2({ placeholder: 'Filter by customer', allowClear: true });
    $('.location-select').select2({ placeholder: 'Search for a location', allowClear: true });

    // Live search — debounce 500ms, use requestSubmit() so Turbo intercepts it
    let searchTimer;
    $('#order-search').on('input', function() {
      clearTimeout(searchTimer);
      var form = document.getElementById('orders-filter-form');
      searchTimer = setTimeout(function() {
        form.requestSubmit();
      }, 500);
    });
  });
</script>
