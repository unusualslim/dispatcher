<div class="container-fluid px-4 py-3">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Quotes</h4>
    <%= link_to new_quote_path, class: "btn btn-primary btn-sm" do %>
      <i class="bi bi-plus-lg"></i> New Quote
    <% end %>
  </div>

  <div class="card shadow-sm">
    <div class="table-responsive">
      <table class="table table-sm table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Quote #</th>
            <th>Customer</th>
            <th>Location</th>
            <th>Total</th>
            <th>Status</th>
            <th>Expires</th>
            <th>Sent</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @quotes.each do |quote| %>
            <tr>
              <td><%= link_to quote.quote_number, quote, class: "fw-semibold text-decoration-none" %></td>
              <td><%= quote.customer.name %></td>
              <td class="text-muted small"><%= quote.location&.company_name %></td>
              <td><%= number_to_currency(quote.total) %></td>
              <td>
                <span class="badge <%= status_badge_class(quote.status) %>"><%= quote.status.capitalize %></span>
              </td>
              <td class="text-muted small"><%= quote.expiry_date&.strftime("%-m/%-d/%y") %></td>
              <td class="text-muted small"><%= quote.sent_at&.strftime("%-m/%-d/%y") %></td>
              <td>
                <%= link_to quote, class: "btn btn-outline-secondary btn-sm" do %>
                  <i class="bi bi-eye"></i>
                <% end %>
              </td>
            </tr>
          <% end %>
          <% if @quotes.empty? %>
            <tr><td colspan="8" class="text-center text-muted py-4">No quotes yet.</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="mt-3"><%= will_paginate @quotes %></div>
</div>
