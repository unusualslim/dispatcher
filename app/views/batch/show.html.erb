<div class="container text-center py-5">
  <p class="text-muted mb-1" style="font-size:0.85rem;letter-spacing:0.08em;text-transform:uppercase;">Batch</p>
  <div class="fw-bold mb-4" style="font-size:clamp(2rem,10vw,4rem);line-height:1.1;font-family:monospace;">
    <%= @batch %>
  </div>

  <p class="text-muted mb-1" style="font-size:0.85rem;letter-spacing:0.08em;text-transform:uppercase;">Date</p>
  <div class="fw-bold" style="font-size:clamp(1.5rem,7vw,3rem);line-height:1.2;">
    <%= @date %>
  </div>
</div>
