<div class="container py-4 no-print">
  <div class="d-flex align-items-center gap-3 mb-4">
    <h4 class="mb-0">Batch Label Generator</h4>
  </div>

  <%# Entry list -%>
  <div id="entries-list" class="mb-3"></div>

  <div class="d-flex flex-wrap gap-2 mb-3">
    <button id="add-entry" type="button" class="btn btn-outline-secondary btn-sm">
      + Add entry
    </button>
    <button id="generate-btn" type="button" class="btn btn-primary btn-sm">
      Generate codes
    </button>
  </div>

  <div class="form-check mb-3">
    <input class="form-check-input" type="checkbox" id="show-captions">
    <label class="form-check-label text-muted small" for="show-captions">
      Print readable caption
      <span class="text-warning">(internal sheets only — captions are human-readable)</span>
    </label>
  </div>

  <button id="print-btn" type="button" class="btn btn-secondary btn-sm mb-3" style="display:none">
    Print sheet
  </button>
</div>

<div id="qr-sheet" class="qr-sheet" style="display:none"></div>
