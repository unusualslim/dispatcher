<div class="container mt-4" style="max-width: 600px;">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Edit Vendor</h1>
    <%= link_to 'Back', vendor_path(@vendor), class: 'btn btn-outline-secondary btn-sm' %>
  </div>

  <% if @vendor.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% @vendor.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with model: @vendor, local: true do |form| %>
    <div class="card shadow-sm mb-3">
      <div class="card-header fw-semibold">Vendor Info</div>
      <div class="card-body row g-3">
        <div class="col-12">
          <%= form.label :name, class: 'form-label' %>
          <%= form.text_field :name, class: 'form-control', required: true %>
        </div>
        <div class="col-6">
          <%= form.label :contact_name, "Contact Name", class: 'form-label' %>
          <%= form.text_field :contact_name, class: 'form-control' %>
        </div>
        <div class="col-6">
          <%= form.label :phone, class: 'form-label' %>
          <%= form.text_field :phone, class: 'form-control' %>
        </div>
        <div class="col-12">
          <%= form.label :email, class: 'form-label' %>
          <%= form.email_field :email, class: 'form-control' %>
        </div>
        <div class="col-6">
          <%= form.label :lead_time_days, "Lead Time (days)", class: 'form-label' %>
          <%= form.number_field :lead_time_days, class: 'form-control', min: 0 %>
        </div>
      </div>
    </div>

    <div class="card shadow-sm mb-3">
      <div class="card-header fw-semibold">PDI Integration</div>
      <div class="card-body">
        <div class="col-12">
          <%= form.label :id, "PDI Vendor ID", class: 'form-label' %>
          <%= form.text_field :id, class: 'form-control', disabled: true %>
          <div class="form-text">The vendor ID is set by PDI and synced automatically.</div>
        </div>
      </div>
    </div>

    <div class="d-flex gap-2">
      <%= form.submit 'Save Changes', class: 'btn btn-success' %>
      <%= link_to 'Cancel', vendor_path(@vendor), class: 'btn btn-secondary' %>
    </div>
  <% end %>
</div>
