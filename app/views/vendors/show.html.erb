<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-2">
    <h1 class="mb-0"><%= @vendor.name %></h1>
    <%= link_to 'Edit', edit_vendor_path(@vendor), class: 'btn btn-outline-secondary btn-sm' %>
  </div>

  <p class="text-muted mb-2">PDI Vendor ID: <strong><%= @vendor.id %></strong></p>

  <div class="row mb-3">
    <div class="col-md-6">
      <div class="card shadow-sm">
        <div class="card-header fw-semibold">Contact & Address</div>
        <div class="card-body">
          <% if @vendor.phone.present? %>
            <p class="mb-1"><strong>Phone:</strong> <%= @vendor.phone %></p>
          <% end %>
          <% if @vendor.email.present? %>
            <p class="mb-1"><strong>Email:</strong> <%= @vendor.email %></p>
          <% end %>
          <% if @vendor.contact_name.present? %>
            <p class="mb-1"><strong>Contact:</strong> <%= @vendor.contact_name %></p>
          <% end %>
          <% if [@vendor.address_1, @vendor.city, @vendor.state].any?(&:present?) %>
            <p class="mb-1 mt-2">
              <% if @vendor.address_1.present? %><%= @vendor.address_1 %><br><% end %>
              <% if @vendor.address_2.present? %><%= @vendor.address_2 %><br><% end %>
              <%= [@vendor.city, @vendor.state].select(&:present?).join(', ') %>
              <%= @vendor.zip %>
            </p>
          <% end %>
          <% if [@vendor.phone, @vendor.email, @vendor.contact_name, @vendor.address_1].none?(&:present?) %>
            <p class="text-muted mb-0">No contact information on file.</p>
          <% end %>
        </div>
      </div>
    </div>
    <% if @vendor.payment_terms.present? || @vendor.payment_method.present? %>
    <div class="col-md-6">
      <div class="card shadow-sm">
        <div class="card-header fw-semibold">Payment</div>
        <div class="card-body">
          <% if @vendor.payment_terms.present? %>
            <p class="mb-1"><strong>Terms:</strong> <%= @vendor.payment_terms %></p>
          <% end %>
          <% if @vendor.payment_method.present? %>
            <p class="mb-1"><strong>Method:</strong> <%= @vendor.payment_method %></p>
          <% end %>
        </div>
      </div>
    </div>
    <% end %>
  </div>

  <hr>

  <h3>Related Dispatches</h3>
  <% if @vendor.dispatches.any? %>
    <table class="table table-striped">
      <thead>
        <tr>
          <th>ID</th>
          <th>Status</th>
          <th>Dispatch Date</th>
          <th>Destination</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @vendor.dispatches.each do |dispatch| %>
          <tr>
            <td><%= dispatch.id %></td>
            <td><%= dispatch.status %></td>
            <td><%= dispatch.dispatch_date || "Not Set" %></td>
            <td><%= dispatch.destination || "No Destination" %></td>
            <td><%= link_to "View Dispatch", dispatch_path(dispatch), class: "btn btn-primary btn-sm" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-muted">No dispatches associated with this vendor.</p>
  <% end %>

  <%= link_to "Back to Vendors", vendors_path, class: "btn btn-secondary mt-3" %>
</div>