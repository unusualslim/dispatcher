<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Locations Map</title>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.7.1/dist/leaflet.css" />
  <style>
    /* Ensure the html and body take up full height */
    html, body {
      height: 100%;
      margin: 0;
      padding: 0;
    }

    /* Map container */
    #map {
      height: 100vh; /* 100% of the viewport height */
      width: 100%; /* 100% of the width */
    }

    /* Custom Legend Styling */
    .legend {
      background: white;
      padding: 10px;
      border-radius: 5px;
      line-height: 1.5;
      font-size: 14px;
      box-shadow: 0 0 10px rgba(0, 0, 0, 0.3);
    }
    .legend i {
      width: 15px;
      height: 15px;
      display: inline-block;
      margin-right: 5px;
      border-radius: 50%;
    }
  </style>
</head>
<body>

  <div id="map"></div>

  <script src="https://unpkg.com/leaflet@1.7.1/dist/leaflet.js"></script>

  <script>
    // Initialize the map
    const map = L.map('map').setView([33.7490, -84.3880], 6); // Centered on Georgia

    // Add OpenStreetMap tiles
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      maxZoom: 19,
      attribution: '© OpenStreetMap contributors'
    }).addTo(map);

    // Pass locations from Rails to JavaScript
    const locations = <%= raw @locations.to_json(only: [:id, :latitude, :longitude, :city, :company_name, :location_category_id, :marker_color], methods: :has_active_order) %>;
    const dispatchRoutes = <%= raw @dispatch_routes.to_json %>;

    locations.forEach(location => {
      let markerColor = location.marker_color;

      if (!markerColor) {
        if (location.has_active_order) {   
          markerColor = "#28a745"; // Green for active orders
        } else {
          switch (location.location_category_id) {
            case 1: markerColor = 'blue'; break;  
            case 2: markerColor = 'red'; break;  
            case 3: markerColor = 'gray'; break;  
            default: markerColor = 'black';       
          }
        }
      }

      const marker = L.circleMarker([location.latitude, location.longitude], {
        radius: 8,
        fillColor: markerColor,
        color: markerColor,
        fillOpacity: 0.8,
        stroke: false
      }).addTo(map);

      marker.bindPopup(`<a href="/locations/${location.id}">${location.company_name}</a>`);
    });

    // Returns a color based on days until dispatch_date
    function routeColor(dispatchDate) {
      if (!dispatchDate) return '#6c757d'; // gray = no date set
      const today = new Date();
      today.setHours(0, 0, 0, 0);
      const days = Math.round((new Date(dispatchDate) - today) / 86400000);
      if (days <= 0) return '#dc3545'; // red — today or overdue
      if (days === 1) return '#fd7e14'; // orange — tomorrow
      if (days === 2) return '#ffc107'; // yellow — 2 days out
      return '#28a745';                 // green — 3+ days
    }

    // Draw route lines for "sent to driver" dispatches
    dispatchRoutes.forEach(dispatch => {
      const color = routeColor(dispatch.dispatch_date);
      dispatch.pickups.forEach(pickup => {
        const coords = [
          [pickup.lat, pickup.lng],
          [dispatch.destination.lat, dispatch.destination.lng]
        ];

        const line = L.polyline(coords, {
          color: color,
          weight: 3,
          opacity: 0.8,
          dashArray: '6, 6'
        }).addTo(map);

        const driverLabel = dispatch.driver ? ` — ${dispatch.driver}` : '';
        const dateLabel = dispatch.dispatch_date ? ` | Due: ${dispatch.dispatch_date}` : '';
        line.bindPopup(`<strong>Dispatch #${dispatch.id}${driverLabel}</strong><br>${pickup.name} → ${dispatch.destination.name}${dateLabel}`);
      });
    });

    // Add a Legend (Key) to the Top-Right Corner
    const legend = L.control({ position: "topright" });

    legend.onAdd = function (map) {
      const div = L.DomUtil.create("div", "legend");
      div.innerHTML = `
        <strong>Map Key</strong><br>
        <i style="background: #28a745"></i> Active Order <br>
        <i style="background: blue"></i> Origin <br>
        <i style="background: red"></i> Destination <br>
        <i style="background: gray"></i> Prospective <br>
        <i style="background: black"></i> Unknown Category <br>
        <hr style="margin: 4px 0">
        <strong>Dispatch Routes</strong><br>
        <i style="background: #28a745; border-radius: 0; height: 3px; margin-top: 6px;"></i> 3+ days out <br>
        <i style="background: #ffc107; border-radius: 0; height: 3px; margin-top: 6px;"></i> 2 days out <br>
        <i style="background: #fd7e14; border-radius: 0; height: 3px; margin-top: 6px;"></i> Tomorrow <br>
        <i style="background: #dc3545; border-radius: 0; height: 3px; margin-top: 6px;"></i> Today / Overdue
      `;
      return div;
    };

    legend.addTo(map);
  </script>

</body>
</html>
