<div class="content">
  <h1>Dispatches</h1>

  <div class="mb-3">
    <%= link_to "Export All Dispatches (CSV)", export_csv_dispatches_path(
      format: :csv,
      status: params[:status],
      driver: params[:driver],
      sort_by: params[:sort_by]
    ), class: "btn btn-success" %>
  </div>

  <!-- Filter and Sorting Form -->
  <div class="mb-4">
    <%= form_with(url: view_dispatches_path, method: :get, local: true, data: { turbo: false }) do %>
      <div class="row mb-3">

        <!-- Status Filter -->
        <div class="col-md-4">
          <%= label_tag :status, 'Status' %>
          <%= select_tag :status, options_for_select(
            [['All', 'all'], ['Incomplete', 'exclude_complete_deleted']] +
            Dispatch.dispatch_statuses.values.map { |status| [status, status] },
            selected: params[:status].presence || 'all'
          ), class: "form-control" %>
        </div>

        <!-- Driver Filter -->
        <div class="col-md-4">
          <%= label_tag :driver, 'Assigned To' %>
          <%= select_tag :driver, options_for_select(
            [['All Drivers', '']] +
            User.all.map { |user| [user.full_name, user.id] },
            selected: params[:driver].presence || ''
          ), class: "form-control" %>
        </div>

        <!-- Sort By -->
        <div class="col-md-4">
          <%= label_tag :sort_by, 'Sort By' %>
          <%= select_tag :sort_by, options_for_select(
            [['Newest', 'newest'], ['Oldest', 'oldest'], ['Dispatch Date', 'dispatch_date']],
            selected: params[:sort_by].presence || 'newest'
          ), class: "form-control" %>
        </div>

        <!-- Buttons -->
        <div class="d-flex justify-content-center" style="gap: 15px; padding-top: 20px;">
          <div style="width: 150px;">
            <%= submit_tag 'Apply Filters', class: 'btn btn-primary btn-md w-100' %>
          </div>
          <div style="width: 150px;">
            <%= link_to 'Clear Filters', view_dispatches_path(page: nil, status: nil, driver: nil, sort_by: nil),
                        class: 'btn btn-secondary btn-md w-100' %>
          </div>
        </div>

      </div>
    <% end %>
  </div>

  <!-- Dispatches Table -->
  <table class="table table-hover">
    <thead>
      <tr>
        <th>ID</th>
        <th>Assigned To</th>
        <th>Dispatch Date</th>
        <th>Status</th>
        <th>Origin</th>
        <th>Destination</th>
        <th>Notes</th>
        <th>Created On</th>
      </tr>
    </thead>
    <tbody>
      <% @dispatches.each do |dispatch| %>
        <tr style="cursor: pointer;" onclick="location.href='/dispatches/<%= dispatch.id %>';">

          <td><%= dispatch.id %></td>
          <td><%= dispatch.driver&.full_name || 'Unassigned' %></td>
          <td><%= dispatch.dispatch_date || 'No date set' %></td>
          <td><%= dispatch.status || 'No status' %></td>
          <td><%= dispatch.origin || "No Origin" %></td>

          <td>
            <% if dispatch.customer_orders.any? %>
              <% destination_location = dispatch.customer_orders.first.location %>
              <%= "#{destination_location.company_name} - #{destination_location.city}" %>
            <% else %>
              No destination location found
            <% end %>
          </td>

          <td><%= dispatch.notes.presence || 'No notes' %></td>
          <td><%= dispatch.created_at.in_time_zone('Eastern Time (US & Canada)').strftime('%Y-%m-%d %I:%M %p') %></td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <!-- PAGINATION (better spacing + guaranteed filter params) -->
  <% pagination_params = params.permit(:status, :driver, :sort_by).to_h %>
  <div class="d-flex justify-content-center mt-3">
    <%= will_paginate @dispatches,
          params: pagination_params,
          previous_label: "&larr; Previous",
          next_label: "Next &rarr;",
          inner_window: 2,
          outer_window: 0 %>
  </div>
</div>

<style>
.table th, .table td {
  text-align: left;
  padding: 10px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.table th:nth-child(1), .table td:nth-child(1) { width: 5%; }
.table th:nth-child(2), .table td:nth-child(2) { width: 15%; }
.table th:nth-child(3), .table td:nth-child(3) { width: 15%; }
.table th:nth-child(4), .table td:nth-child(4) { width: 10%; }
.table th:nth-child(5), .table td:nth-child(5) { width: 20%; }
.table th:nth-child(6), .table td:nth-child(6) { width: 20%; }
.table th:nth-child(7), .table td:nth-child(7) { width: 10%; }
.table th:nth-child(8), .table td:nth-child(8) { width: 15%; }

/* will_paginate spacing fix */
.pagination {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
  margin-top: 16px;
  padding-left: 0;
}

.pagination a,
.pagination span {
  display: inline-block;
  padding: 8px 12px;
  border: 1px solid #ddd;
  border-radius: 6px;
  text-decoration: none;
  line-height: 1;
}

.pagination .current {
  font-weight: 700;
}

.pagination .disabled {
  opacity: 0.5;
}
</style>
