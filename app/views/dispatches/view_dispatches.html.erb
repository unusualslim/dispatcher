<link rel="stylesheet" href="https://unpkg.com/leaflet@1.7.1/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.7.1/dist/leaflet.js"></script>

<style>
  .dispatch-split { display: flex; gap: 12px; height: calc(100vh - 180px); overflow: hidden; }
  .dispatch-table-pane { flex: 0 0 55%; overflow-y: auto; }
  .dispatch-right-pane { flex: 1; min-height: 0; position: relative; }

  #dispatch-map { height: 100%; width: 100%; border-radius: 8px; }

  /* Detail panel sits on top of map */
  #dispatch-detail {
    display: none;
    position: absolute;
    inset: 0;
    background: #fff;
    border-radius: 8px;
    overflow-y: auto;
    box-shadow: 0 2px 12px rgba(0,0,0,.15);
    z-index: 10;
  }
  #dispatch-detail.visible { display: block; }

  .dispatch-row { cursor: pointer; transition: background .12s; }
  .dispatch-row:hover  { background: #eef4ff !important; }
  .dispatch-row.active-row { background: #ddeeff !important; }
  .dispatch-row.selected-row { background: #ddeeff !important; font-weight: 500; }

  @media (max-width: 900px) {
    .dispatch-split { flex-direction: column; height: auto; overflow: visible; }
    .dispatch-table-pane { flex: none; overflow-y: visible; }
    .dispatch-right-pane { flex: none; height: 420px; }
  }
</style>

<%# ── Header + filters ── %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <h4 class="mb-0 fw-bold">Dispatches</h4>
  <%= link_to "Export CSV", export_csv_dispatches_path(format: :csv, status: params[:status], driver: params[:driver], sort_by: params[:sort_by]),
        class: "btn btn-success btn-sm" %>
</div>

<div class="card shadow-sm mb-3">
  <div class="card-body py-2">
    <%= form_with url: view_dispatches_path, method: :get, local: true, data: { turbo: false } do %>
      <div class="d-flex gap-2 flex-wrap align-items-end">
        <div>
          <%= label_tag :status, 'Status', class: 'form-label mb-1 small text-muted' %>
          <%= select_tag :status, options_for_select(
                [['All', 'all'], ['Incomplete', 'exclude_complete_deleted']] +
                Dispatch.dispatch_statuses.values.map { |s| [s, s] },
                selected: params[:status].presence || 'all'
              ), class: "form-select form-select-sm", style: "min-width:160px;" %>
        </div>
        <div>
          <%= label_tag :driver, 'Driver', class: 'form-label mb-1 small text-muted' %>
          <%= select_tag :driver, options_for_select(
                [['All Drivers', '']] + User.all.map { |u| [u.full_name, u.id] },
                selected: params[:driver].presence || ''
              ), class: "form-select form-select-sm", style: "min-width:160px;" %>
        </div>
        <div>
          <%= label_tag :sort_by, 'Sort', class: 'form-label mb-1 small text-muted' %>
          <%= select_tag :sort_by, options_for_select(
                [['Dispatch Date', 'dispatch_date'], ['Newest', 'newest'], ['Oldest', 'oldest']],
                selected: params[:sort_by].presence || 'dispatch_date'
              ), class: "form-select form-select-sm", style: "min-width:140px;" %>
        </div>
        <%= submit_tag 'Apply', class: 'btn btn-primary btn-sm align-self-end' %>
        <%= link_to 'Clear', view_dispatches_path, class: 'btn btn-outline-secondary btn-sm align-self-end' %>
      </div>
    <% end %>
  </div>
</div>

<%# ── Split layout ── %>
<div class="dispatch-split">

  <%# Left: table %>
  <div class="dispatch-table-pane">
    <table class="table table-hover table-sm align-middle mb-0" style="font-size:.85rem;">
      <thead class="table-light" style="position:sticky;top:0;z-index:1;">
        <tr>
          <th>#</th>
          <th>Driver</th>
          <th>Date</th>
          <th>Status</th>
          <th>Origin</th>
          <th>Destination</th>
          <th>Orders</th>
        </tr>
      </thead>
      <tbody>
        <% @dispatches.each do |dispatch| %>
          <% dest = dispatch.customer_orders.first&.location %>
          <tr class="dispatch-row"
              data-dispatch-id="<%= dispatch.id %>">
            <td class="fw-semibold"><%= dispatch.id %></td>
            <td><%= dispatch.driver&.full_name || '<span class="text-muted">—</span>'.html_safe %></td>
            <td class="text-muted"><%= dispatch.dispatch_date&.strftime("%b %-d, %Y") || '—' %></td>
            <td>
              <% cls = case dispatch.status
                       when "Sent to Driver" then "bg-warning text-dark"
                       when "Complete"       then "bg-success"
                       when "New"            then "bg-primary"
                       else "bg-secondary"
                       end %>
              <span class="badge <%= cls %>" style="font-size:.7rem;"><%= dispatch.status %></span>
            </td>
            <td class="text-muted text-truncate" style="max-width:120px;"><%= dispatch.origin.presence || '—' %></td>
            <td class="text-truncate" style="max-width:120px;"><%= dest&.company_name || '—' %></td>
            <td class="text-muted"><%= dispatch.customer_orders.size %></td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <% pagination_params = params.permit(:status, :driver, :sort_by).to_h %>
    <div class="d-flex justify-content-center mt-3 mb-2">
      <%= will_paginate @dispatches,
            params: pagination_params,
            previous_label: "&larr;",
            next_label: "&rarr;",
            inner_window: 2,
            outer_window: 0 %>
    </div>
  </div>

  <%# Right: map + detail panel %>
  <div class="dispatch-right-pane">
    <div id="dispatch-map"></div>

    <div id="dispatch-detail">
      <div class="p-3">
        <div class="d-flex justify-content-between align-items-start mb-3">
          <div>
            <h5 class="mb-0 fw-bold" id="detail-title"></h5>
            <div class="text-muted small" id="detail-meta"></div>
          </div>
          <div class="d-flex gap-2">
            <a id="detail-link" href="#" class="btn btn-sm btn-primary">View Full Dispatch</a>
            <button class="btn btn-sm btn-outline-secondary" onclick="closeDetail()">← Map</button>
          </div>
        </div>

        <div class="d-flex gap-3 mb-3 flex-wrap" id="detail-badges"></div>

        <div id="detail-notes" class="alert alert-light py-2 mb-3" style="font-size:.85rem; display:none;"></div>

        <h6 class="fw-semibold mb-2">Orders</h6>
        <div id="detail-orders"></div>
      </div>
    </div>
  </div>

</div>

<script>
  const mapData    = <%= raw @map_data.to_json %>;
  const detailData = <%= raw @dispatch_detail_data.to_json %>;
  const detailIndex = {};
  detailData.forEach(d => detailIndex[d.id] = d);

  // ── Map setup ──
  const map = L.map('dispatch-map').setView([33.0, -83.5], 7);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    maxZoom: 19, attribution: '© OpenStreetMap contributors'
  }).addTo(map);

  function routeColor(dateStr) {
    if (!dateStr) return '#6c757d';
    const today = new Date(); today.setHours(0,0,0,0);
    const days = Math.round((new Date(dateStr) - today) / 86400000);
    if (days <= 0) return '#dc3545';
    if (days === 1) return '#fd7e14';
    if (days === 2) return '#ffc107';
    return '#28a745';
  }

  const lines = {};
  mapData.forEach(d => {
    const color = routeColor(d.dispatch_date);
    const line = L.polyline(
      [[d.origin.lat, d.origin.lng], [d.destination.lat, d.destination.lng]],
      { color, weight: 3, opacity: 0.65, dashArray: '6,5' }
    ).addTo(map);
    line.bindPopup(`<strong>Dispatch #${d.id}</strong>${d.driver ? ' — ' + d.driver : ''}<br>${d.origin.name} → ${d.destination.name}`);
    L.circleMarker([d.origin.lat,      d.origin.lng],      { radius: 5, fillColor: '#0d6efd', color: '#fff', weight: 1.5, fillOpacity: 0.9 }).addTo(map);
    L.circleMarker([d.destination.lat, d.destination.lng], { radius: 5, fillColor: color,     color: '#fff', weight: 1.5, fillOpacity: 0.9 }).addTo(map);
    lines[d.id] = { line, color };
  });

  const allCoords = mapData.flatMap(d => [[d.origin.lat, d.origin.lng], [d.destination.lat, d.destination.lng]]);
  if (allCoords.length) map.fitBounds(allCoords, { padding: [30, 30] });

  // ── Highlight on hover ──
  function highlight(id, on) {
    const entry = lines[id];
    if (!entry) return;
    if (on) {
      entry.line.setStyle({ weight: 6, opacity: 1, dashArray: null });
      entry.line.openPopup();
      map.fitBounds(entry.line.getBounds(), { padding: [80, 80], maxZoom: 11 });
    } else {
      entry.line.setStyle({ weight: 3, opacity: 0.65, dashArray: '6,5', color: entry.color });
      entry.line.closePopup();
    }
  }

  // ── Detail panel ──
  let selectedId = null;

  function statusClass(s) {
    if (s === 'Sent to Driver') return 'bg-warning text-dark';
    if (s === 'Complete')       return 'bg-success';
    if (s === 'New')            return 'bg-primary';
    return 'bg-secondary';
  }

  function openDetail(id) {
    const d = detailIndex[id];
    if (!d) return;
    selectedId = id;

    document.getElementById('detail-title').textContent = `Dispatch #${d.id}`;
    document.getElementById('detail-meta').textContent =
      [d.driver ? `Driver: ${d.driver}` : 'Unassigned', d.dispatch_date].filter(Boolean).join('  ·  ');
    document.getElementById('detail-link').href = `/dispatches/${d.id}`;

    const badges = document.getElementById('detail-badges');
    badges.innerHTML = `<span class="badge ${statusClass(d.status)}">${d.status}</span>` +
      `<span class="badge bg-light text-dark border">${d.orders.length} order${d.orders.length !== 1 ? 's' : ''}</span>` +
      `<span class="text-muted small">${d.origin}</span>`;

    const notesEl = document.getElementById('detail-notes');
    if (d.notes) { notesEl.textContent = d.notes; notesEl.style.display = ''; }
    else         { notesEl.style.display = 'none'; }

    const ordersEl = document.getElementById('detail-orders');
    if (d.orders.length === 0) {
      ordersEl.innerHTML = '<p class="text-muted fst-italic">No orders on this dispatch.</p>';
    } else {
      ordersEl.innerHTML = d.orders.map(o => {
        const products = o.products.map(p =>
          `<span class="badge bg-light text-dark border me-1">${p.name}${p.quantity ? ' · ' + Number(p.quantity).toLocaleString() : ''}</span>`
        ).join('');
        const due = o.due ? `<span class="text-muted ms-2" style="font-size:.78rem;">Due ${o.due}</span>` : '';
        return `
          <div class="card mb-2 shadow-sm">
            <div class="card-body py-2 px-3">
              <div class="d-flex justify-content-between align-items-start">
                <div>
                  <a href="/customer_orders/${o.id}" class="fw-semibold text-decoration-none" onclick="event.stopPropagation()">
                    Order #${o.id}
                  </a>${due}
                  <div class="text-muted small">${o.location || '—'}${o.city ? ', ' + o.city : ''}</div>
                </div>
                <span class="badge bg-light text-dark border" style="font-size:.7rem;">${o.status || ''}</span>
              </div>
              <div class="mt-1">${products}</div>
            </div>
          </div>`;
      }).join('');
    }

    document.getElementById('dispatch-detail').classList.add('visible');

    // Highlight the route on the map (still visible behind panel on mobile)
    if (lines[id]) {
      lines[id].line.setStyle({ weight: 6, opacity: 1, dashArray: null });
    }

    document.querySelectorAll('.dispatch-row').forEach(r => r.classList.remove('selected-row'));
    const row = document.querySelector(`.dispatch-row[data-dispatch-id="${id}"]`);
    if (row) row.classList.add('selected-row');
  }

  function closeDetail() {
    document.getElementById('dispatch-detail').classList.remove('visible');
    if (selectedId && lines[selectedId]) {
      lines[selectedId].line.setStyle({ weight: 3, opacity: 0.65, dashArray: '6,5', color: lines[selectedId].color });
    }
    document.querySelectorAll('.dispatch-row').forEach(r => r.classList.remove('selected-row'));
    selectedId = null;
  }

  document.querySelectorAll('.dispatch-row').forEach(row => {
    const id = parseInt(row.dataset.dispatchId);
    row.addEventListener('mouseenter', () => { if (id !== selectedId) highlight(id, true); });
    row.addEventListener('mouseleave', () => { if (id !== selectedId) highlight(id, false); });
    row.addEventListener('click',      () => openDetail(id));
  });
</script>

<style>
.pagination { display:flex; justify-content:center; align-items:center; gap:6px; flex-wrap:wrap; padding-left:0; }
.pagination a, .pagination span { display:inline-block; padding:5px 10px; border:1px solid #ddd; border-radius:5px; text-decoration:none; font-size:.82rem; }
.pagination .current { font-weight:700; }
.pagination .disabled { opacity:.4; }
</style>
