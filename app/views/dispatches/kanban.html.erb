<!DOCTYPE html>
<html>
<head>
  <title>Dispatch Kanban</title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag 'application', media: 'all' %>
  <%= javascript_include_tag 'application', 'data-turbo-track': 'reload', defer: true %>
  <style>
    *, *::before, *::after { box-sizing: border-box; }

    body {
      font-family: 'Roboto', sans-serif;
      background-color: #f4f4f9;
      margin: 0;
      padding: 0;
    }

    /* ── Toolbar ── */
    .kanban-toolbar {
      position: sticky;
      top: 0;
      z-index: 100;
      background: #fff;
      border-bottom: 1px solid #dee2e6;
      padding: .6rem 1rem;
      display: flex;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
      box-shadow: 0 2px 4px rgba(0,0,0,.06);
    }
    .kanban-toolbar h1 {
      font-size: 1.1rem;
      font-weight: 600;
      margin: 0;
      white-space: nowrap;
    }
    .back-link {
      color: #6c757d;
      text-decoration: none;
      font-size: .85rem;
      white-space: nowrap;
    }
    .back-link:hover { color: #333; }
    .toolbar-divider {
      width: 1px;
      height: 1.4rem;
      background: #dee2e6;
      flex-shrink: 0;
    }
    .filter-label {
      font-size: .8rem;
      color: #6c757d;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: .04em;
      white-space: nowrap;
    }
    .driver-pills {
      display: flex;
      flex-wrap: wrap;
      gap: .35rem;
    }
    .driver-pill {
      background: #f0f0f0;
      border: 1px solid #dee2e6;
      border-radius: 999px;
      padding: .2rem .75rem;
      font-size: .8rem;
      cursor: pointer;
      transition: background .15s, color .15s, border-color .15s;
      white-space: nowrap;
    }
    .driver-pill:hover { background: #e2e6ea; }
    .driver-pill.active {
      background: #0d6efd;
      color: #fff;
      border-color: #0d6efd;
    }

    /* ── Unassigned section ── */
    #unassigned-orders-section {
      padding: .75rem 1rem;
      background: #fff8e1;
      border-bottom: 1px solid #ffe082;
    }
    .unassigned-header {
      display: flex;
      align-items: center;
      gap: .5rem;
      margin-bottom: .6rem;
    }
    .unassigned-header h2 {
      font-size: 1rem;
      font-weight: 600;
      margin: 0;
      color: #795548;
    }
    .unassigned-count {
      background: #ff8f00;
      color: #fff;
      border-radius: 999px;
      font-size: .72rem;
      font-weight: 700;
      padding: .1rem .5rem;
    }
    .unassigned-orders-container {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
    }
    .order-card {
      background: #fff;
      border: 1px solid #dee2e6;
      border-radius: .35rem;
      padding: .75rem;
      width: 230px;
      box-shadow: 0 1px 3px rgba(0,0,0,.08);
      text-decoration: none;
      color: inherit;
      transition: transform .15s, box-shadow .15s;
      display: block;
    }
    .order-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 4px 10px rgba(0,0,0,.13);
    }
    .order-card h3 {
      margin: 0 0 6px;
      font-size: .95rem;
      color: #333;
    }
    .order-card p {
      margin: 3px 0;
      font-size: .82rem;
      color: #555;
    }
    .order-card p strong { color: #333; }
    .no-unassigned {
      font-size: .9rem;
      color: #795548;
      font-style: italic;
    }

    /* ── Kanban board ── */
    .kanban-board {
      display: flex;
      padding: 1rem;
      gap: .75rem;
      overflow-x: auto;
      align-items: flex-start;
      min-height: calc(100vh - 120px);
    }

    .kanban-column {
      flex: 0 0 220px;
      background: #f8f9fa;
      border: 1px solid #dee2e6;
      border-radius: .4rem;
      box-shadow: 0 1px 3px rgba(0,0,0,.07);
      display: flex;
      flex-direction: column;
    }
    .kanban-column.today {
      background: #e8f4fd;
      border-color: #90caf9;
    }

    .column-header {
      background: #f8f9fa;
      border-bottom: 1px solid #dee2e6;
      border-radius: .4rem .4rem 0 0;
      padding: .6rem .75rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: .5rem;
    }
    .today .column-header {
      background: #e8f4fd;
      border-bottom-color: #90caf9;
    }

    .column-date {
      font-size: .9rem;
      font-weight: 600;
      color: #333;
      display: flex;
      align-items: center;
      gap: .4rem;
    }
    .today-badge {
      background: #0d6efd;
      color: #fff;
      font-size: .65rem;
      font-weight: 700;
      letter-spacing: .05em;
      padding: .1rem .4rem;
      border-radius: 999px;
    }
    .column-count {
      background: #6c757d;
      color: #fff;
      border-radius: 999px;
      font-size: .7rem;
      font-weight: 700;
      padding: .1rem .45rem;
      min-width: 1.4rem;
      text-align: center;
    }
    .today .column-count { background: #0d6efd; }

    .kanban-cards {
      padding: .6rem;
      display: flex;
      flex-direction: column;
      gap: .5rem;
      min-height: 80px;
    }

    /* ── Dispatch cards ── */
    .kanban-card {
      background: #fff;
      border: 1px solid #dee2e6;
      border-radius: .35rem;
      padding: .65rem .75rem;
      box-shadow: 0 1px 3px rgba(0,0,0,.07);
      transition: transform .15s, box-shadow .15s;
      cursor: pointer;
      text-decoration: none;
      color: inherit;
      display: block;
      border-left-width: 4px;
    }
    .kanban-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 10px rgba(0,0,0,.12);
    }
    .kanban-card[data-hidden="true"] { display: none; }

    /* Status border colors */
    .kanban-card.status-new            { border-left-color: #0d6efd; }
    .kanban-card.status-sent_to_driver { border-left-color: #fd7e14; }
    .kanban-card.status-complete       { border-left-color: #198754; }
    .kanban-card.status-billed         { border-left-color: #6f42c1; }

    .card-header-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: .35rem;
    }
    .card-dispatch-id {
      font-size: .88rem;
      font-weight: 700;
      color: #0d6efd;
    }
    .card-status-badge {
      font-size: .68rem;
      font-weight: 600;
      padding: .15rem .45rem;
      border-radius: 999px;
      text-transform: capitalize;
      white-space: nowrap;
    }
    .badge-new            { background: #cfe2ff; color: #084298; }
    .badge-sent_to_driver { background: #ffe5d0; color: #7d3c00; }
    .badge-complete       { background: #d1e7dd; color: #0a3622; }
    .badge-billed         { background: #e8d5f5; color: #3b1070; }

    .card-row {
      font-size: .8rem;
      color: #555;
      margin: 2px 0;
      display: flex;
      gap: .3rem;
    }
    .card-row strong { color: #333; flex-shrink: 0; }
    .card-meta {
      display: flex;
      gap: .5rem;
      margin-top: .4rem;
      flex-wrap: wrap;
    }
    .card-meta-chip {
      background: #f0f0f0;
      border-radius: 999px;
      font-size: .72rem;
      padding: .1rem .45rem;
      color: #555;
    }
    .card-notes {
      font-size: .78rem;
      color: #888;
      margin-top: .3rem;
      font-style: italic;
      overflow: hidden;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
    }

    .empty-column-msg {
      font-size: .8rem;
      color: #aaa;
      text-align: center;
      padding: .5rem 0;
      font-style: italic;
    }
  </style>
</head>
<body>

  <!-- Toolbar -->
  <div class="kanban-toolbar">
    <%= link_to dispatches_path, class: 'back-link' do %>&larr; Dispatches<% end %>
    <div class="toolbar-divider"></div>
    <h1>Dispatch Kanban</h1>
    <div class="toolbar-divider"></div>
    <span class="filter-label">Driver</span>
    <div class="driver-pills">
      <button class="driver-pill active" data-driver-id="all">All</button>
      <% @drivers.each do |driver| %>
        <button class="driver-pill" data-driver-id="<%= driver.id %>"><%= driver.full_name %></button>
      <% end %>
    </div>
  </div>

  <!-- Unassigned Orders -->
  <div id="unassigned-orders-section">
    <div class="unassigned-header">
      <h2>Unassigned Orders</h2>
      <span class="unassigned-count"><%= @unassigned_orders.size %></span>
    </div>
    <% if @unassigned_orders.any? %>
      <div class="unassigned-orders-container">
        <% @unassigned_orders.each do |order| %>
          <% company_name = order.location&.company_name || "No Location" %>
          <% top_product = order.customer_order_products.max_by { |cop| cop.quantity || 0 } %>
          <% total_count = order.customer_order_products.count %>
          <% _pname = top_product&.then { |cop| cop.product&.name || cop.product_name } %>
          <% product_display = if total_count == 1
                                  _pname
                                elsif total_count > 1
                                  "#{_pname} +#{total_count - 1}"
                                else
                                  "No Products"
                                end %>
          <% top_qty = top_product&.quantity || 0 %>
          <% uom = top_product&.product&.unit_of_measurement || "units" %>
          <% qty_display = total_count >= 1 ? "#{number_with_delimiter(top_qty.to_i)} #{uom}#{total_count > 1 ? " +#{total_count - 1}" : ""}" : "Not Set" %>
          <% card_color = order.card_color || '#0d6efd' %>

          <%= link_to customer_order_path(order), class: 'order-card', style: "border-left: 4px solid #{card_color};" do %>
            <h3>Order #<%= order.id %></h3>
            <p><strong>Location:</strong> <%= company_name %></p>
            <p><strong>Product:</strong> <%= product_display %></p>
            <p><strong>Amount:</strong> <%= qty_display %></p>
            <p><strong>Deliver by:</strong> <%= order.required_delivery_date&.strftime("%b %d") || "—" %></p>
            <% if order.freight_only? %>
              <p><span class="badge bg-warning text-dark" style="font-size:.7rem;">Freight Only</span></p>
            <% end %>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <p class="no-unassigned">No unassigned orders.</p>
    <% end %>
  </div>

  <!-- Kanban Board -->
  <div class="kanban-board">
    <% start_date = Date.yesterday %>
    <% end_date = Date.today + 6.days %>
    <% (start_date..end_date).each do |date| %>
      <% day_dispatches = @dispatches_by_date[date] || [] %>
      <% next if date < Date.yesterday && day_dispatches.empty? %>
      <% is_today = date == Date.today %>

      <div class="kanban-column <%= 'today' if is_today %>">
        <div class="column-header">
          <div class="column-date">
            <% if is_today %><span class="today-badge">TODAY</span><% end %>
            <%= date.strftime("%a, %b %-d") %>
          </div>
          <span class="column-count" data-count-for="<%= date %>"><%= day_dispatches.count %></span>
        </div>

        <div class="kanban-cards">
          <% if day_dispatches.empty? %>
            <span class="empty-column-msg">No dispatches</span>
          <% end %>

          <% day_dispatches.each do |dispatch| %>
            <% status_key = dispatch.status.to_s %>
            <% order_count = dispatch.customer_orders.size %>
            <% total_qty = dispatch.customer_orders.sum { |o| o.customer_order_products.sum { |cop| cop.quantity || 0 } } %>

            <%= link_to dispatch_path(dispatch),
                  class: "kanban-card status-#{status_key}",
                  data: { driver_id: dispatch.driver_id.to_s } do %>

              <div class="card-header-row">
                <span class="card-dispatch-id">Dispatch #<%= dispatch.id %></span>
                <span class="card-status-badge badge-<%= status_key %>"><%= status_key.tr('_', ' ') %></span>
              </div>

              <div class="card-row">
                <strong>Driver:</strong>
                <%= dispatch.driver&.full_name || "Unassigned" %>
              </div>
              <div class="card-row">
                <strong>Origin:</strong>
                <%= dispatch.origin.presence || "—" %>
              </div>
              <div class="card-row">
                <strong>To:</strong>
                <% if dispatch.customer_orders.any? && dispatch.customer_orders.first.location %>
                  <%= "#{dispatch.customer_orders.first.location.company_name} – #{dispatch.customer_orders.first.location.city}" %>
                <% else %>
                  <%= dispatch.destination.presence || "—" %>
                <% end %>
              </div>

              <div class="card-meta">
                <span class="card-meta-chip"><%= order_count %> <%= "order".pluralize(order_count) %></span>
                <% if total_qty > 0 %>
                  <span class="card-meta-chip"><%= number_with_delimiter(total_qty.to_i) %> gal</span>
                <% end %>
              </div>

              <% if dispatch.notes.present? %>
                <div class="card-notes"><%= dispatch.notes %></div>
              <% end %>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <script>
    // Driver filter pills
    const pills = document.querySelectorAll('.driver-pill');
    pills.forEach(pill => {
      pill.addEventListener('click', function () {
        pills.forEach(p => p.classList.remove('active'));
        this.classList.add('active');
        const target = this.dataset.driverId;

        document.querySelectorAll('.kanban-card').forEach(card => {
          const match = target === 'all' || card.dataset.driverId === target;
          card.dataset.hidden = match ? 'false' : 'true';
        });

        // Update column count badges to reflect visible cards only
        document.querySelectorAll('.kanban-column').forEach(col => {
          const visible = col.querySelectorAll('.kanban-card:not([data-hidden="true"])').length;
          col.querySelector('.column-count').textContent = visible;
        });
      });
    });
  </script>

</body>
</html>
