<%# ── Announcements ── %>
<% if Announcement.active.any? %>
  <div style="background:#d1ecf1;border-bottom:1px solid #bee5eb;padding:.6rem 1rem;">
    <% Announcement.active.order(published_at: :desc).each do |ann| %>
      <div class="d-flex align-items-start gap-2 mb-1" id="ann-<%= ann.id %>">
        <i class="bi bi-megaphone-fill text-info mt-1"></i>
        <div class="flex-grow-1">
          <strong><%= ann.title %></strong>
          <span class="text-muted ms-2" style="font-size:.85rem;"><%= ann.published_at.in_time_zone('Eastern Time (US & Canada)').strftime("%b %-d") %></span>
        </div>
        <button class="btn-close btn-sm" onclick="document.getElementById('ann-<%= ann.id %>').remove()"></button>
      </div>
    <% end %>
  </div>
<% end %>

<style>
  .stat-card { text-decoration:none; color:inherit; display:block; transition:transform .15s, box-shadow .15s; }
  .stat-card:hover { transform:translateY(-3px); box-shadow:0 6px 16px rgba(0,0,0,.12) !important; color:inherit; }
  .section-card-link { text-decoration:none; color:inherit; font-weight:600; }
  .section-card-link:hover { text-decoration:underline; color:#0d6efd; }
</style>

<div class="container-fluid px-4 py-3">

  <%# ── Page header ── %>
  <div class="d-flex align-items-center justify-content-between mb-3">
    <h4 class="mb-0 fw-bold">Dashboard</h4>
    <span class="text-muted" style="font-size:.85rem;"><%= Date.today.strftime("%A, %B %-d, %Y") %></span>
  </div>

  <%# ── Stat cards ── %>
  <div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
      <%= link_to view_dispatches_path(status: "exclude_complete_deleted"), class: 'stat-card' do %>
        <div class="card shadow-sm h-100 border-0" style="border-left:4px solid #0d6efd !important;">
          <div class="card-body py-3">
            <div class="text-muted mb-1" style="font-size:.75rem;text-transform:uppercase;letter-spacing:.05em;">Active Dispatches</div>
            <div class="fw-bold" style="font-size:2rem;line-height:1;"><%= @stat_active %></div>
            <div class="text-muted mt-1" style="font-size:.8rem;">New or sent to driver &rarr;</div>
          </div>
        </div>
      <% end %>
    </div>
    <div class="col-6 col-md-3">
      <%= link_to view_dispatches_path(status: "Sent to Driver"), class: 'stat-card' do %>
        <div class="card shadow-sm h-100 border-0" style="border-left:4px solid #fd7e14 !important;">
          <div class="card-body py-3">
            <div class="text-muted mb-1" style="font-size:.75rem;text-transform:uppercase;letter-spacing:.05em;">In Transit</div>
            <div class="fw-bold" style="font-size:2rem;line-height:1;"><%= @stat_in_transit %></div>
            <div class="text-muted mt-1" style="font-size:.8rem;">Sent to driver &rarr;</div>
          </div>
        </div>
      <% end %>
    </div>
    <div class="col-6 col-md-3">
      <%= link_to customer_orders_path(order_status: "unassigned"), class: 'stat-card' do %>
        <div class="card shadow-sm h-100 border-0" style="border-left:4px solid #dc3545 !important;">
          <div class="card-body py-3">
            <div class="text-muted mb-1" style="font-size:.75rem;text-transform:uppercase;letter-spacing:.05em;">Unassigned Orders</div>
            <div class="fw-bold" style="font-size:2rem;line-height:1;"><%= @stat_unassigned %></div>
            <div class="text-muted mt-1" style="font-size:.8rem;">Need a dispatch &rarr;</div>
          </div>
        </div>
      <% end %>
    </div>
    <div class="col-6 col-md-3">
      <%= link_to customer_orders_path(order_status: "On Hold"), class: 'stat-card' do %>
        <div class="card shadow-sm h-100 border-0" style="border-left:4px solid #ffc107 !important;">
          <div class="card-body py-3">
            <div class="text-muted mb-1" style="font-size:.75rem;text-transform:uppercase;letter-spacing:.05em;">On Hold</div>
            <div class="fw-bold" style="font-size:2rem;line-height:1;"><%= @stat_on_hold %></div>
            <div class="text-muted mt-1" style="font-size:.8rem;">Orders paused &rarr;</div>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <%# ── Main two-column ── %>
  <div class="row g-3 mb-3">

    <%# Today's dispatches %>
    <div class="col-lg-7">
      <div class="card shadow-sm h-100">
        <div class="card-header d-flex align-items-center justify-content-between py-2">
          <%= link_to "Today's Dispatches", kanban_dispatches_path(start_date: Date.today, end_date: Date.today), class: 'section-card-link' %>
          <div class="d-flex align-items-center gap-2">
            <span class="badge bg-primary"><%= @today_dispatches.count %></span>
            <%= link_to "Kanban →", kanban_dispatches_path(start_date: Date.today, end_date: Date.today), class: 'btn btn-sm btn-outline-primary', style: 'font-size:.75rem;padding:.15rem .5rem;' %>
          </div>
        </div>
        <% if @today_dispatches.empty? %>
          <div class="card-body text-muted fst-italic" style="font-size:.9rem;">No dispatches scheduled for today.</div>
        <% else %>
          <div class="table-responsive">
            <table class="table table-hover mb-0" style="font-size:.85rem;">
              <thead class="table-light">
                <tr>
                  <th class="ps-3">#</th>
                  <th>Driver</th>
                  <th>Status</th>
                  <th>From</th>
                  <th>To</th>
                  <th>Orders</th>
                </tr>
              </thead>
              <tbody>
                <% @today_dispatches.each do |d| %>
                  <% first_order = d.customer_orders.first %>
                  <tr style="cursor:pointer;" onclick="location.href='<%= dispatch_path(d) %>'">
                    <td class="ps-3"><%= link_to "##{d.id}", dispatch_path(d), class: 'fw-semibold text-decoration-none' %></td>
                    <td><%= d.driver&.full_name || '<span class="text-danger">Unassigned</span>'.html_safe %></td>
                    <td>
                      <% cls = d.status == "Sent to Driver" ? "bg-warning text-dark" : "bg-primary" %>
                      <span class="badge <%= cls %>" style="font-size:.7rem;"><%= d.status %></span>
                    </td>
                    <td class="text-muted"><%= d.origin.presence || "—" %></td>
                    <td><%= first_order&.location&.company_name || d.destination.presence || "—" %></td>
                    <td><%= d.customer_orders.size %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% end %>
      </div>
    </div>

    <%# Unassigned orders %>
    <div class="col-lg-5">
      <div class="card shadow-sm h-100">
        <div class="card-header d-flex align-items-center justify-content-between py-2">
          <%= link_to "Unassigned Orders", customer_orders_path(order_status: "unassigned"), class: 'section-card-link' %>
          <div class="d-flex gap-2 align-items-center">
            <span class="badge bg-danger"><%= @stat_unassigned %></span>
            <%= link_to "View All →", customer_orders_path(order_status: "unassigned"), class: 'btn btn-sm btn-outline-danger', style: 'font-size:.75rem;padding:.15rem .5rem;' %>
          </div>
        </div>
        <% if @unassigned_orders.empty? %>
          <div class="card-body text-muted fst-italic" style="font-size:.9rem;">All orders are assigned.</div>
        <% else %>
          <div style="max-height:320px;overflow-y:auto;">
            <table class="table table-hover mb-0" style="font-size:.83rem;">
              <thead class="table-light" style="position:sticky;top:0;z-index:1;">
                <tr>
                  <th class="ps-3">#</th>
                  <th>Location</th>
                  <th>Due</th>
                  <th>Product</th>
                </tr>
              </thead>
              <tbody>
                <% @unassigned_orders.each do |o| %>
                  <% top = o.customer_order_products.select { |c| c.product }.max_by { |c| c.quantity || 0 } %>
                  <% due = o.required_delivery_date %>
                  <% overdue = due && due < Date.today %>
                  <tr style="cursor:pointer;" onclick="location.href='<%= customer_order_path(o) %>'">
                    <td class="ps-3"><%= link_to "##{o.id}", customer_order_path(o), class: 'text-decoration-none fw-semibold' %></td>
                    <td><%= o.location&.company_name || "—" %></td>
                    <td class="<%= overdue ? 'text-danger fw-semibold' : '' %>">
                      <%= due ? due.strftime("%b %-d") : "—" %>
                      <% if overdue %><i class="bi bi-exclamation-circle ms-1"></i><% end %>
                    </td>
                    <td class="text-muted">
                      <%= top ? (top.product&.name || top.product_name) : "—" %>
                      <% extras = o.customer_order_products.count - 1 %>
                      <% if extras > 0 %><span class="text-muted"> +<%= extras %></span><% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%# ── Upcoming dispatches ── %>
  <% if @upcoming_dispatches.any? %>
    <div class="card shadow-sm mb-3">
      <div class="card-header d-flex align-items-center justify-content-between py-2">
        <%= link_to "Upcoming Dispatches", kanban_dispatches_path(start_date: Date.today + 1, end_date: Date.today + 7), class: 'section-card-link' %>
        <div class="d-flex align-items-center gap-2">
          <span class="text-muted fw-normal" style="font-size:.8rem;">next 7 days</span>
          <%= link_to "Kanban →", kanban_dispatches_path(start_date: Date.today + 1, end_date: Date.today + 7), class: 'btn btn-sm btn-outline-secondary', style: 'font-size:.75rem;padding:.15rem .5rem;' %>
        </div>
      </div>
      <div class="table-responsive">
        <table class="table table-hover mb-0" style="font-size:.85rem;">
          <thead class="table-light">
            <tr>
              <th class="ps-3">#</th>
              <th>Date</th>
              <th>Driver</th>
              <th>Status</th>
              <th>From</th>
              <th>To</th>
              <th>Orders</th>
            </tr>
          </thead>
          <tbody>
            <% @upcoming_dispatches.each do |d| %>
              <% first_order = d.customer_orders.first %>
              <% days_out = (d.dispatch_date - Date.today).to_i %>
              <tr style="cursor:pointer;" onclick="location.href='<%= dispatch_path(d) %>'">
                <td class="ps-3"><%= link_to "##{d.id}", dispatch_path(d), class: 'fw-semibold text-decoration-none' %></td>
                <td>
                  <%= d.dispatch_date.strftime("%a, %b %-d") %>
                  <span class="text-muted ms-1" style="font-size:.75rem;">in <%= days_out %> <%= "day".pluralize(days_out) %></span>
                </td>
                <td><%= d.driver&.full_name || '<span class="text-muted fst-italic">Unassigned</span>'.html_safe %></td>
                <td>
                  <% cls = d.status == "Sent to Driver" ? "bg-warning text-dark" : "bg-primary" %>
                  <span class="badge <%= cls %>" style="font-size:.7rem;"><%= d.status %></span>
                </td>
                <td class="text-muted"><%= d.origin.presence || "—" %></td>
                <td><%= first_order&.location&.company_name || d.destination.presence || "—" %></td>
                <td><%= d.customer_orders.size %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>

  <%# ── On Hold Orders ── %>
  <% if @on_hold_orders.any? %>
    <div class="card shadow-sm mb-3">
      <div class="card-header d-flex align-items-center justify-content-between py-2">
        <%= link_to "On Hold Orders", customer_orders_path(order_status: "On Hold"), class: 'section-card-link' %>
        <div class="d-flex align-items-center gap-2">
          <span class="badge bg-warning text-dark"><%= @on_hold_orders.count %></span>
          <%= link_to "View All →", customer_orders_path(order_status: "On Hold"), class: 'btn btn-sm btn-outline-warning', style: 'font-size:.75rem;padding:.15rem .5rem;' %>
        </div>
      </div>
      <div class="table-responsive">
        <table class="table table-hover mb-0" style="font-size:.85rem;">
          <thead class="table-light">
            <tr>
              <th class="ps-3">#</th>
              <th>Location</th>
              <th>Due</th>
              <th>Notes</th>
            </tr>
          </thead>
          <tbody>
            <% @on_hold_orders.each do |o| %>
              <tr style="cursor:pointer;" onclick="location.href='<%= customer_order_path(o) %>'">
                <td class="ps-3"><%= link_to "##{o.id}", customer_order_path(o), class: 'fw-semibold text-decoration-none' %></td>
                <td><%= o.location&.company_name || "—" %></td>
                <td><%= o.required_delivery_date&.strftime("%b %-d, %Y") || "—" %></td>
                <td class="text-muted"><%= o.try(:notes).presence || "—" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>

</div>
