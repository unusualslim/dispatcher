<div class="container-fluid px-4 py-4">

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-semibold mb-0">Users</h4>
    <%= link_to new_user_registration_path, class: "btn btn-primary btn-sm" do %>
      <i class="bi bi-person-plus"></i> Add User
    <% end %>
  </div>

  <%# ── Admins ──────────────────────────────────────────────────────────────────── %>
  <% admins  = @users.select { |u| u.role == 'admin' } %>
  <% drivers = @users.select { |u| u.role != 'admin' } %>

  <% [["Admins", admins], ["Drivers", drivers]].each do |section_title, group| %>
    <div class="mb-4">
      <h6 class="text-muted text-uppercase fw-semibold mb-2" style="font-size:.75rem; letter-spacing:.05em;">
        <%= section_title %> (<%= group.size %>)
      </h6>
      <div class="card shadow-sm">
        <% if group.empty? %>
          <div class="card-body text-muted fst-italic">None.</div>
        <% else %>
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th>Name</th>
                  <th>Email</th>
                  <th>Phone</th>
                  <th>Notifications</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% group.each do |user| %>
                  <tr style="cursor:pointer;" onclick="window.location='<%= user_path(user) %>'">
                    <td>
                      <div class="fw-semibold"><%= user.full_name.presence || "—" %></div>
                      <div class="text-muted small"><%= user.role&.capitalize %></div>
                    </td>
                    <td><%= user.email %></td>
                    <td><%= user.phone_number.presence || "—" %></td>
                    <td>
                      <% if user.email_opt_in? %>
                        <span class="badge bg-light text-dark border me-1"><i class="bi bi-envelope"></i> Email</span>
                      <% end %>
                      <% if user.sms_opt_in? %>
                        <span class="badge bg-light text-dark border"><i class="bi bi-phone"></i> SMS</span>
                      <% end %>
                      <% unless user.email_opt_in? || user.sms_opt_in? %>
                        <span class="text-muted small">None</span>
                      <% end %>
                    </td>
                    <td class="text-end" onclick="event.stopPropagation()">
                      <%= link_to edit_user_path(user), class: "btn btn-sm btn-outline-secondary me-1" do %>
                        <i class="bi bi-pencil"></i>
                      <% end %>
                      <%= form_with url: user_path(user), method: :delete, class: "d-inline" do %>
                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete"
                                data-confirm="Delete <%= user.full_name %>?">
                          <i class="bi bi-trash"></i>
                        </button>
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

</div>
