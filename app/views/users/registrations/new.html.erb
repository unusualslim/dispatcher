<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
      <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
          <h4 class="mb-0">Add New User</h4>
        </div>
        <div class="card-body p-4">

          <% if flash[:recaptcha_error].present? %>
            <div class="alert alert-warning"><%= flash[:recaptcha_error] %></div>
          <% end %>

          <% if @user.errors.any? %>
            <div class="alert alert-danger">
              <ul class="mb-0 ps-3">
                <% @user.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <%= form_with(model: @user, url: user_registration_path, data: { turbo: false }, class: "needs-validation") do |form| %>

            <div class="row g-3 mb-3">
              <div class="col">
                <%= form.label :first_name, class: "form-label" %>
                <%= form.text_field :first_name, class: "form-control", placeholder: "First name", required: true %>
              </div>
              <div class="col">
                <%= form.label :last_name, class: "form-label" %>
                <%= form.text_field :last_name, class: "form-control", placeholder: "Last name", required: true %>
              </div>
            </div>

            <div class="mb-3">
              <%= form.label :email, class: "form-label" %>
              <%= form.email_field :email, class: "form-control", placeholder: "email@example.com", required: true %>
            </div>

            <div class="mb-3">
              <%= form.label :phone_number, class: "form-label" %>
              <%= form.text_field :phone_number, class: "form-control", placeholder: "Phone number" %>
            </div>

            <div class="mb-3">
              <%= form.label :role, class: "form-label" %>
              <%= form.select :role,
                    [['Worker (Driver)', 'worker'], ['Admin', 'admin']],
                    { prompt: 'Select role...' },
                    class: "form-select", required: true %>
            </div>

            <div class="mb-3">
              <%= form.label :password, class: "form-label" %>
              <%= form.password_field :password, class: "form-control", placeholder: "Password", required: true %>
            </div>

            <div class="mb-3">
              <%= form.label :password_confirmation, "Confirm Password", class: "form-label" %>
              <%= form.password_field :password_confirmation, class: "form-control", placeholder: "Confirm password", required: true %>
            </div>

            <div class="mb-4">
              <%= recaptcha_tags %>
            </div>

            <div class="d-grid">
              <%= form.submit 'Create User', class: 'btn btn-primary btn-lg' %>
            </div>

          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<% if flash[:recaptcha_error].present? %>
<script>
  // Reset the reCAPTCHA widget so the spent token doesn't cause every retry to fail
  if (typeof grecaptcha !== 'undefined') { grecaptcha.reset(); }
</script>
<% end %>
