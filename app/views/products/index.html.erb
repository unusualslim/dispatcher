<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="mb-0">Products</h1>
  <div class="d-flex gap-2 align-items-center">
    <button type="button" class="btn btn-success btn-sm d-none" id="create-po-selected">
      Create PO for Selected (<span id="selected-count">0</span>)
    </button>
    <%= link_to 'MRP Dashboard', mrp_path, class: 'btn btn-outline-primary btn-sm' %>
    <%= link_to 'New Product', new_product_path, class: 'btn btn-primary btn-sm' %>
  </div>
</div>

<%# Search + filters %>
<div class="card shadow-sm mb-3">
  <div class="card-body py-2">
    <%= form_with url: products_path, method: :get, local: true,
          data: { turbo_frame: "products-results" } do |f| %>
      <div class="d-flex gap-2 flex-wrap align-items-center">
        <div class="input-group" style="max-width: 280px;">
          <%= f.text_field :query, value: params[:query], placeholder: 'Search products…',
                class: 'form-control form-control-sm', id: 'product-search',
                autocomplete: 'off' %>
        </div>

        <% active_type = params[:type].presence || 'finished' %>
        <select name="type" class="form-select form-select-sm" style="max-width: 160px;" onchange="this.form.requestSubmit()">
          <option value="all"     <%= 'selected' if active_type == 'all' %>>All Types</option>
          <option value="finished" <%= 'selected' if active_type == 'finished' %>>Finished Goods</option>
          <option value="raw"      <%= 'selected' if active_type == 'raw' %>>Raw Materials</option>
        </select>

        <select name="category" class="form-select form-select-sm" style="max-width: 200px;" onchange="this.form.requestSubmit()">
          <option value="">All Categories</option>
          <% @categories.each do |cat| %>
            <option value="<%= cat %>" <%= 'selected' if params[:category] == cat %>><%= cat %></option>
          <% end %>
        </select>

        <select name="status" class="form-select form-select-sm" style="max-width: 160px;" onchange="this.form.requestSubmit()">
          <option value="">All Statuses</option>
          <option value="critical" <%= 'selected' if params[:status] == 'critical' %>>Critical</option>
          <option value="low"      <%= 'selected' if params[:status] == 'low' %>>Low</option>
          <option value="ok"       <%= 'selected' if params[:status] == 'ok' %>>OK</option>
        </select>

        <% if params[:query].present? || params[:type].present? || params[:category].present? || params[:status].present? || params[:sort].present? %>
          <%= link_to 'Clear', products_path, class: 'btn btn-outline-danger btn-sm' %>
        <% end %>

        <%= f.hidden_field :sort, value: params[:sort] %>
      </div>
    <% end %>
  </div>
</div>

<%# helper for sortable column headers %>
<% sort_url = ->(col) {
  products_path(query: params[:query], type: params[:type], category: params[:category], status: params[:status], sort: col)
} %>

<turbo-frame id="products-results">
  <% if @products.empty? %>
    <div class="text-center text-muted py-5">No products match your filters.</div>
  <% else %>
    <div class="text-muted small mb-2"><%= @products.size %> product<%= 's' unless @products.size == 1 %> found</div>
    <div class="table-responsive">
      <table class="table table-hover align-middle">
        <thead class="table-light">
          <tr>
            <th style="width:32px">
              <input type="checkbox" class="form-check-input" id="select-all-products">
            </th>
            <th>ID</th>
            <th><%= link_to "Name", sort_url.call(params[:sort] == 'name_asc' ? 'name_desc' : 'name_asc'), class: 'text-decoration-none text-dark' %></th>
            <th><%= link_to "Category", sort_url.call(params[:sort] == 'category_asc' ? 'category_desc' : 'category_asc'), class: 'text-decoration-none text-dark' %></th>
            <th>Type</th>
            <th>Unit</th>
            <th><%= link_to "On Hand", sort_url.call(params[:sort] == 'stock_asc' ? 'stock_desc' : 'stock_asc'), class: 'text-decoration-none text-dark' %></th>
            <th>On Order</th>
            <th>Committed</th>
            <th>Available</th>
            <th>Reorder Point</th>
            <th><%= link_to "Cost/Unit", sort_url.call('cost'), class: 'text-decoration-none text-dark' %></th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @products.each do |product| %>
            <tr>
              <td>
                <input type="checkbox" class="form-check-input product-select" value="<%= product.id %>">
              </td>
              <td><code class="small"><%= product.id %></code></td>
              <td><%= link_to product.name, product_path(product), class: "text-decoration-none fw-semibold", data: { turbo_frame: "_top" } %></td>
              <td><span class="badge bg-secondary"><%= product.category.presence || '—' %></span></td>
              <td>
                <% if product.is_raw_material? %>
                  <span class="badge bg-secondary">Raw Material</span>
                <% else %>
                  <span class="badge bg-info text-dark">Finished Good</span>
                <% end %>
              </td>
              <td class="text-muted"><%= product.unit_of_measurement %></td>
              <td><%= number_with_precision(product.current_stock, precision: 1) %></td>
              <td class="text-success"><%= number_with_precision(product.on_order_qty, precision: 1) %></td>
              <td class="text-warning"><%= number_with_precision(product.committed_qty, precision: 1) %></td>
              <td class="<%= product.available_stock < 0 ? 'text-danger fw-bold' : '' %>">
                <%= number_with_precision(product.available_stock, precision: 1) %>
              </td>
              <td><%= product.reorder_point ? number_with_precision(product.reorder_point, precision: 1) : '—' %></td>
              <td><%= product.cost_per_unit ? number_to_currency(product.cost_per_unit) : '—' %></td>
              <td>
                <% status = product.stock_status %>
                <% if status == :critical %>
                  <span class="badge bg-danger">Critical</span>
                <% elsif status == :low %>
                  <span class="badge bg-warning text-dark">Low</span>
                <% elsif status == :ok %>
                  <span class="badge bg-success">OK</span>
                <% else %>
                  <span class="badge bg-light text-muted">—</span>
                <% end %>
              </td>
              <td>
                <div class="d-flex gap-1">
                  <%= link_to 'Edit', edit_product_path(product), class: 'btn btn-warning btn-sm', data: { turbo_frame: "_top" } %>
                  <%= link_to 'Adjust', new_inventory_adjustment_path(product_id: product.id), class: 'btn btn-outline-secondary btn-sm' %>
                  <%= button_to 'Delete', product_path(product),
                        method: :delete,
                        data: { confirm: 'Are you sure?' },
                        class: 'btn btn-danger btn-sm',
                        form: { style: 'display: inline;' } %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</turbo-frame>

<script>
  (function() {
    // Search debounce
    var input = document.getElementById('product-search');
    if (input) {
      var timer;
      input.addEventListener('input', function() {
        clearTimeout(timer);
        timer = setTimeout(function() { input.closest('form').requestSubmit(); }, 300);
      });
    }

    // Multi-select PO creation — persists across turbo-frame re-renders
    const selectedIds = new Set();

    function updateButton() {
      const btn      = document.getElementById('create-po-selected');
      const countEl  = document.getElementById('selected-count');
      if (!btn) return;
      countEl.textContent = selectedIds.size;
      btn.classList.toggle('d-none', selectedIds.size === 0);
    }

    function bindCheckboxes() {
      const selectAll = document.getElementById('select-all-products');
      const checkboxes = document.querySelectorAll('.product-select');

      // Restore checked state after frame re-render
      checkboxes.forEach(cb => { cb.checked = selectedIds.has(cb.value); });
      if (selectAll) selectAll.checked = checkboxes.length > 0 && Array.from(checkboxes).every(cb => cb.checked);

      selectAll?.addEventListener('change', function() {
        checkboxes.forEach(cb => {
          cb.checked = this.checked;
          this.checked ? selectedIds.add(cb.value) : selectedIds.delete(cb.value);
        });
        updateButton();
      });

      checkboxes.forEach(cb => cb.addEventListener('change', function() {
        this.checked ? selectedIds.add(this.value) : selectedIds.delete(this.value);
        if (selectAll) selectAll.checked = Array.from(checkboxes).every(c => c.checked);
        updateButton();
      }));
    }

    // Initial bind
    bindCheckboxes();

    // Re-bind after turbo-frame updates (search/filter)
    document.addEventListener('turbo:frame-render', function(e) {
      if (e.target.id === 'products-results') { bindCheckboxes(); updateButton(); }
    });

    document.getElementById('create-po-selected')?.addEventListener('click', function() {
      const params = Array.from(selectedIds).map(id => `product_ids[]=${id}`).join('&');
      window.location.href = '<%= new_purchase_order_path %>?' + params;
    });
  })();
</script>
