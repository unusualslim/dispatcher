<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <div>
      <h1 class="mb-0"><%= @product.name %></h1>
      <div class="text-muted small">Product ID: <%= @product.id %></div>
    </div>
    <%= link_to "Back", products_path, class: "btn btn-outline-secondary btn-sm" %>
  </div>

  <%# MRP inventory card %>
  <div class="card shadow-sm mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
      <span class="fw-semibold">Inventory & MRP</span>
      <% if @product.is_raw_material? %>
        <span class="badge bg-secondary">Raw Material</span>
      <% else %>
        <span class="badge bg-info text-dark">Finished Good</span>
      <% end %>
    </div>
    <div class="card-body">
      <div class="row g-3 text-center">
        <div class="col-3">
          <div class="text-muted small">Current Stock</div>
          <div class="fs-5 fw-bold"><%= number_with_precision(@product.current_stock, precision: 1) %> <%= @product.unit_of_measurement %></div>
        </div>
        <div class="col-3">
          <div class="text-muted small">Available</div>
          <div class="fs-5 fw-bold"><%= number_with_precision(@product.available_stock, precision: 1) %></div>
        </div>
        <div class="col-3">
          <div class="text-muted small">Reorder Point</div>
          <div class="fs-5 fw-bold"><%= @product.reorder_point ? number_with_precision(@product.reorder_point, precision: 1) : '—' %></div>
        </div>
        <div class="col-3">
          <div class="text-muted small">Safety Stock</div>
          <div class="fs-5 fw-bold"><%= number_with_precision(@product.safety_stock, precision: 1) %></div>
        </div>
      </div>
      <% status = @product.stock_status %>
      <% if status != :unknown %>
        <div class="mt-3 text-center">
          <% if status == :critical %>
            <span class="badge bg-danger fs-6">CRITICAL — Below Safety Stock</span>
          <% elsif status == :low %>
            <span class="badge bg-warning text-dark fs-6">LOW — At or Below Reorder Point</span>
          <% else %>
            <span class="badge bg-success fs-6">Stock OK</span>
          <% end %>
        </div>
      <% end %>
      <div class="mt-3 d-flex gap-2 justify-content-end">
        <%= link_to 'Edit Settings', edit_product_path(@product), class: 'btn btn-sm btn-outline-secondary' %>
        <%= link_to 'Adjust Stock', new_inventory_adjustment_path(product_id: @product.id), class: 'btn btn-sm btn-outline-warning' %>
        <%= link_to 'Create Purchase Order', new_purchase_order_path(product_id: @product.id), class: 'btn btn-sm btn-outline-primary' %>
      </div>
    </div>
  </div>

  <%# Open Purchase Orders %>
  <% if @open_purchase_orders.any? %>
    <div class="card shadow-sm mb-3">
      <div class="card-header fw-semibold">Open Purchase Orders</div>
      <div class="table-responsive">
        <table class="table table-sm mb-0">
          <thead class="table-light">
            <tr><th>#</th><th>Vendor</th><th>Qty</th><th>Status</th><th>Expected</th><th></th></tr>
          </thead>
          <tbody>
            <% @open_purchase_orders.each do |po| %>
              <tr>
                <td><%= link_to "##{po.id}", purchase_order_path(po), class: 'fw-semibold text-decoration-none' %></td>
                <td><%= po.vendor.name %></td>
                <td><%= number_with_precision(po.quantity, precision: 1) %> <%= @product.unit_of_measurement %></td>
                <td><span class="badge bg-secondary"><%= po.status.humanize %></span></td>
                <td><%= po.expected_delivery_date&.strftime("%b %-d, %Y") || '—' %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>

  <%# Recent Inventory Transactions %>
  <div class="card shadow-sm mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
      <span class="fw-semibold">Recent Inventory Activity</span>
      <%= link_to 'Full History →', inventory_transactions_path(product_id: @product.id), class: 'btn btn-sm btn-outline-secondary' %>
    </div>
    <% if @recent_transactions.empty? %>
      <div class="card-body text-muted fst-italic" style="font-size:.9rem;">No transactions recorded yet.</div>
    <% else %>
      <div class="table-responsive">
        <table class="table table-sm mb-0">
          <thead class="table-light">
            <tr><th>Date</th><th>Direction</th><th>Qty</th><th>Notes</th><th>By</th></tr>
          </thead>
          <tbody>
            <% @recent_transactions.each do |tx| %>
              <tr>
                <td class="text-muted" style="font-size:.85rem;"><%= tx.created_at.strftime("%b %-d, %Y") %></td>
                <td>
                  <% if tx.direction == 'in' %>
                    <span class="badge bg-success">IN</span>
                  <% else %>
                    <span class="badge bg-danger">OUT</span>
                  <% end %>
                </td>
                <td><%= number_with_precision(tx.quantity, precision: 1) %></td>
                <td class="text-muted" style="font-size:.85rem;"><%= tx.notes.presence || '—' %></td>
                <td class="text-muted" style="font-size:.85rem;"><%= tx.created_by&.full_name || '—' %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </div>

  <div class="card shadow-sm">
    <div class="card-body">
      <h5 class="mb-3">Components (BOM)</h5>

      <%= form_with model: @product, local: true do |f| %>
        <% if @product.errors.any? %>
          <div class="alert alert-danger">
            <strong><%= pluralize(@product.errors.count, "error") %> prevented saving:</strong>
            <ul class="mb-0">
              <% @product.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div id="bom-rows" class="d-flex flex-column gap-2">
          <%= f.fields_for :product_components do |pc| %>
            <div class="d-flex gap-2 align-items-center" data-bom-row="1">
              <%= pc.hidden_field :id if pc.object&.persisted? %>

              <%= pc.collection_select :component_product_id,
                    Product.order(:name),
                    :id,
                    :name,
                    { include_blank: "Select component..." },
                    class: "form-select" %>

              <%= pc.number_field :quantity_per_unit,
                    step: 0.001,
                    class: "form-control",
                    placeholder: "Qty / unit" %>

              <%= pc.text_field :uom,
                    class: "form-control",
                    placeholder: "UOM (e.g. GAL)" %>

              <div class="form-check ms-1">
                <%= pc.check_box :_destroy, class: "form-check-input" %>
                <%= pc.label :_destroy, "Remove", class: "form-check-label small" %>
              </div>
            </div>
          <% end %>
        </div>

        <button type="button" class="btn btn-sm btn-outline-secondary mt-3" id="add-bom-row">
          + Add Component
        </button>

        <div class="mt-3">
          <%= f.submit "Save BOM", class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
  window.bomProducts = <%= Product.order(:name).map { |p| { id: p.id, name: p.name } }.to_json.html_safe %>;
</script>

<script>
document.addEventListener("turbo:load", function () {
  var container = document.getElementById("bom-rows");
  var addBtn    = document.getElementById("add-bom-row");
  if (!container || !addBtn || addBtn.dataset.bound) return;
  addBtn.dataset.bound = "1";

  function nextIndex() {
    var max = -1;
    container.querySelectorAll('input, select').forEach(function (el) {
      var m = el.name && el.name.match(/\[product_components_attributes\]\[(\d+)\]/);
      if (m) max = Math.max(max, parseInt(m[1], 10));
    });
    return max + 1;
  }

  function productOptions() {
    return window.bomProducts.map(function (p) {
      return '<option value="' + p.id + '">' + p.name + '</option>';
    }).join('');
  }

  addBtn.addEventListener("click", function () {
    var idx  = nextIndex();
    var base = 'product[product_components_attributes][' + idx + ']';
    var html = '<div class="d-flex gap-2 align-items-center" data-bom-row="1">' +
      '<select class="form-select" name="' + base + '[component_product_id]">' +
        '<option value="">Select component...</option>' + productOptions() +
      '</select>' +
      '<input class="form-control" type="number" step="0.001" placeholder="Qty / unit" name="' + base + '[quantity_per_unit]" />' +
      '<input class="form-control" type="text" placeholder="UOM (e.g. GAL)" name="' + base + '[uom]" />' +
      '<div class="form-check ms-1">' +
        '<input class="form-check-input" type="checkbox" name="' + base + '[_destroy]" />' +
        '<label class="form-check-label small">Remove</label>' +
      '</div>' +
    '</div>';

    container.insertAdjacentHTML("beforeend", html);
  });
});
</script>