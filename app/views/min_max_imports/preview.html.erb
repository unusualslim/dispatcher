<div class="d-flex justify-content-between align-items-start mb-3">
  <div>
    <h1 class="mb-1">Preview Min/Max Import</h1>
    <p class="text-muted mb-0">
      <span class="text-success fw-semibold"><%= @update_count %> products will be updated</span>
      <% if @skip_no_product > 0 %>
        &nbsp;&middot;&nbsp;<span class="text-danger fw-semibold"><%= @skip_no_product %> part numbers not found</span>
      <% end %>
      &nbsp;&middot;&nbsp;<span class="text-muted"><%= @skip_no_values %> rows skipped (no values)</span>
    </p>
  </div>
  <%= link_to "Cancel", new_min_max_import_path, class: "btn btn-outline-secondary" %>
</div>

<%= form_with url: min_max_import_path, method: :post, data: { turbo: false } do |f| %>
  <div class="card shadow-sm mb-3">
    <div class="table-responsive">
      <table class="table table-sm table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>Part #</th>
            <th>Product Name</th>
            <th class="text-end">Min (Reorder Point)</th>
            <th class="text-end">Max Stock</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% @rows.select { |r| r.action == :update }.each do |row| %>
            <tr>
              <td class="font-monospace small text-muted"><%= row.part_id %></td>
              <td><%= row.product.name %></td>
              <td class="text-end">
                <% if row.min_old != row.min_new %>
                  <span class="text-muted"><%= row.min_old&.to_i || '—' %></span>
                  <i class="bi bi-arrow-right text-muted mx-1"></i>
                  <strong><%= row.min_new&.to_i || '—' %></strong>
                <% else %>
                  <span class="text-muted"><%= row.min_new&.to_i || '—' %> (no change)</span>
                <% end %>
              </td>
              <td class="text-end">
                <% if row.max_old != row.max_new %>
                  <span class="text-muted"><%= row.max_old&.to_i || '—' %></span>
                  <i class="bi bi-arrow-right text-muted mx-1"></i>
                  <strong><%= row.max_new&.to_i || '—' %></strong>
                <% else %>
                  <span class="text-muted"><%= row.max_new&.to_i || '—' %> (no change)</span>
                <% end %>
              </td>
              <td><span class="badge bg-success">Update</span></td>
            </tr>
          <% end %>
          <% @rows.select { |r| r.action == :skip_no_product }.each do |row| %>
            <tr class="text-muted">
              <td class="font-monospace small"><%= row.part_id %></td>
              <td><em>Not found</em></td>
              <td class="text-end"><%= row.min_new&.to_i || '—' %></td>
              <td class="text-end"><%= row.max_new&.to_i || '—' %></td>
              <td><span class="badge bg-danger">Not Found</span></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="d-flex gap-2 mt-3 mb-5">
    <%= f.submit "Confirm Import", class: "btn btn-success btn-lg" %>
    <%= link_to "Cancel", new_min_max_import_path, class: "btn btn-outline-secondary btn-lg" %>
  </div>
<% end %>
