<div class="container mt-4" style="max-width: 640px;">
  <h1>Import Min/Max Levels</h1>
  <p class="text-muted">Import reorder points and max stock levels from the Inventory Min-Max sheet.</p>

  <% if @products_with_minmax > 0 %>
    <div class="alert alert-info">
      <strong><%= @products_with_minmax %> products already have min/max values set.</strong>
      Re-importing will overwrite existing values for any matching part numbers.
    </div>
  <% end %>

<%= form_with url: min_max_import_path, method: :post, local: true, multipart: true do |f| %>
    <div class="card shadow-sm">
      <div class="card-body">
        <div class="mb-3">
          <%= f.label :file, "Inventory Min-Max Sheet (.xlsx)", class: "form-label fw-semibold" %>
          <%= f.file_field :file, class: "form-control", accept: ".xlsx" %>
          <div class="form-text">Use the <em>MASTER Product List</em> sheet — reads Min → reorder point, Max → max stock.</div>
        </div>
        <%= f.submit "Import Min/Max", class: "btn btn-primary" %>
      </div>
    </div>
  <% end %>

  <div class="card shadow-sm mt-3">
    <div class="card-header fw-semibold">What this does</div>
    <div class="card-body small text-muted">
      <ul class="mb-0">
        <li>Reads the <strong>MASTER Product List</strong> sheet only</li>
        <li>Matches rows to LoadNTrucks products by Part# (column A)</li>
        <li>Sets <strong>Reorder Point</strong> from the Min column</li>
        <li>Sets <strong>Max Stock</strong> from the Max column</li>
        <li>Skips rows with no min or max value set</li>
        <li>Skips part numbers not found in LoadNTrucks</li>
        <li>Safe to re-run — overwrites previous values</li>
      </ul>
    </div>
  </div>

  <%= link_to "← Back", products_path, class: "btn btn-outline-secondary mt-3" %>

  <%= render 'shared/import_history', logs: @logs, download_path: :download_min_max_import_path %>
</div>
