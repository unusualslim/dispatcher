<header class="topbar d-flex align-items-center justify-content-between px-4" data-turbo="false">
  <!-- Mobile hamburger -->
  <button class="sidebar-toggle-btn d-lg-none me-3" id="sidebarToggle" type="button">
    <i class="bi bi-list fs-4"></i>
  </button>

  <div class="flex-grow-1"></div>

  <!-- Quick actions -->
  <div class="d-flex align-items-center gap-2">
    <% if user_signed_in? %>
      <% unless driver? %>
        <%= link_to "New Order", new_customer_order_path, class: "btn btn-success btn-sm" %>
        <%= link_to "New Dispatch", new_dispatch_path, class: "btn btn-primary btn-sm" %>
      <% end %>
    <% else %>
      <%= link_to 'Sign In', new_user_session_path, class: 'btn btn-outline-light btn-sm' %>
    <% end %>
  </div>
</header>
