<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <title>Batch Labels</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <%= csrf_meta_tags %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <%= javascript_include_tag "batch_labels", defer: false %>
    <style>
      body { background: #f8f9fa; }

      /* ── QR sheet — screen ──────────────────────────────────── */
      .qr-sheet {
        padding: 16px;
      }
      /* One 4×6 label = 2×2 grid of QR codes */
      .label-sheet {
        display: inline-grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
        padding: 12px;
        background: #fff;
        border: 2px solid #adb5bd;
        border-radius: 4px;
        margin-bottom: 20px;
      }
      .qr-label {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 6px;
      }
      /* Scale down high-res canvas for screen preview */
      .qr-label canvas {
        width: 140px;
        height: 140px;
      }
      .qr-caption {
        margin-top: 5px;
        font-size: 10px;
        font-family: monospace;
        text-align: center;
        color: #333;
        max-width: 140px;
        overflow-wrap: break-word;
      }

      /* ── Print — 4 QR codes per 4×6 inch label ──────────── */
      @media print {
        .no-print { display: none !important; }
        body { background: #fff; margin: 0; padding: 0; }

        .qr-sheet { padding: 0; }

        .label-sheet {
          display: grid !important;
          grid-template-columns: 2in 2in;
          grid-template-rows: 3in 3in;
          width: 4in;
          height: 6in;
          gap: 0;
          padding: 0;
          margin: 0;
          border: none;
          page-break-after: always;
          break-after: page;
          overflow: hidden;
        }

        .qr-label {
          width: 2in;
          height: 3in;
          display: flex;
          flex-direction: column;
          align-items: center;
          justify-content: center;
          padding: 0.1in;
          page-break-inside: avoid;
          break-inside: avoid;
        }

        /* Override screen canvas size — fill the cell at print DPI */
        .qr-label canvas {
          width: 1.75in !important;
          height: 1.75in !important;
        }

        .qr-caption {
          font-size: 7pt;
          margin-top: 3px;
          max-width: 1.75in;
        }
      }
    </style>
    <%= yield :head %>
  </head>
  <body>
    <% if flash[:alert] %>
      <div class="alert alert-danger alert-dismissible fade show m-3 no-print" role="alert">
        <%= flash[:alert] %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% end %>
    <%= yield %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
